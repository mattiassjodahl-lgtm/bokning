        _mockBalances.TryGetValue(name.Trim(), out var b) ? b : new(0, 0m);

    // ── Lägg till deltagare (grupplektion, view mode) ─────────────────────────

    private void ConfirmAddParticipant()
    {
        _participantError = "";
        var ok = BookingService.AddParticipantToEvent(ExistingEvent!.Id, _newParticipantName);
        if (ok)
        {
            _newParticipantName = "";
            _addingParticipant  = false;
        }
        else
        {
            _participantError = "Kunde inte lägga till — platsen kan vara full eller eleven redan bokad.";
        }
    }

    // ── Resource toggle ───────────────────────────────────────────────────────

    private void ToggleResource(int resourceId)
    {
        if (_request.SelectedResourceIds.Contains(resourceId))
            _request.SelectedResourceIds.Remove(resourceId);
        else
            _request.SelectedResourceIds.Add(resourceId);
    }

    // ── Submit ────────────────────────────────────────────────────────────────

    private async Task OnSubmit()
    {
        await _form.Validate();
        if (!_isValid) return;

        // Synka kategori mot den valda elevens faktiska kategorier vid prov-bokning.
        // Skyddar mot att default-värdet "B" sparas om eleven faktiskt har A1/AM.
        var licenseCategory = _request.LicenseCategory;
        if (IsExamType)
        {
            var elevCats = AvailableLicenseCategories.ToList();
            if (string.IsNullOrWhiteSpace(licenseCategory) || !elevCats.Contains(licenseCategory!))
                licenseCategory = elevCats.FirstOrDefault();
        }
        else
        {
            licenseCategory = null;
        }

        foreach (var row in _rows)
        {
            var date = row.Date ?? DateTime.Today;
            BookingService.AddBooking(new BookingRequest
            {
                TeacherId           = _request.TeacherId,
                StartTime           = date.Add(row.StartTime ?? TimeSpan.Zero),
                EndTime             = date.Add(row.EndTime   ?? TimeSpan.FromHours(1)),
                StudentName         = _request.StudentName,
                ExtraStudents       = IsSharedLesson
                                          ? _extraStudents.Where(s => !string.IsNullOrWhiteSpace(s)).ToList()
                                          : new(),
                LessonTypeId        = _request.LessonTypeId,
                SelectedResourceIds = _request.SelectedResourceIds.ToList(),
                Notes               = _request.Notes,
                PickupLocationId    = _request.PickupLocationId,
                LicenseCategory     = licenseCategory,
            });
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void OnCancelBooking()
    {
        BookingService.CancelBooking(ExistingEvent!.Id);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void OnBookExisting()
        => MudDialog.Close(DialogResult.Ok("book_existing"));

    private void Close() => MudDialog.Cancel();
}
