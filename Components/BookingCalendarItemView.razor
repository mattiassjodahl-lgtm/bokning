@* Renders a single calendar item inside MudCalendar *@

@{
    var evt     = Item.Event;
    var teacher = BookingService.GetTeacher(evt.TeacherId);
    var lt      = evt.LessonTypeId.HasValue ? BookingService.GetLessonType(evt.LessonTypeId.Value) : null;
}

<div style="padding:2px 4px;font-size:11px;line-height:1.3;overflow:hidden;height:100%;
            background-color:@(evt.IsBooked ? (lt?.LightColor ?? "#E3F2FD") : "#E8F5E9");
            border-left:3px solid @(evt.IsBooked ? (lt?.Color ?? "#1565C0") : "#2E7D32");
            border-radius:2px"
     title="@(evt.IsBooked ? $"{evt.StudentName} – {lt?.Name}" : $"Ledig: {lt?.Name ?? "okänd typ"}")">

    <div style="font-size:10px;color:#757575;white-space:nowrap">
        @evt.StartTime.ToString("HH:mm")–@evt.EndTime.ToString("HH:mm")
    </div>

    @if (evt.IsBooked)
    {
        @if (lt is { MaxStudents: > 1 })
        {
            @* Group lesson – show capacity badge *@
            var booked    = evt.AllStudentNames.Count();
            var pct       = (double)booked / lt.MaxStudents;
            var badgeColor = pct >= 0.9 ? "#f44336" : pct >= 0.5 ? "#ff9800" : "#4caf50";
            <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@lt.Name</div>
            <span style="font-size:9px;padding:0 4px;border-radius:8px;background:@badgeColor;color:white">
                @booked/@lt.MaxStudents
            </span>
        }
        else if (evt.ExtraStudents.Any())
        {
            <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                @evt.StudentName
                <span style="font-size:9px;padding:0 3px;border-radius:6px;background:#1565C0;color:white;margin-left:2px">+@evt.ExtraStudents.Count</span>
            </div>
        }
        else
        {
            <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@evt.StudentName</div>
        }

        @if (lt != null && lt.MaxStudents <= 1)
        {
            <div style="font-size:10px;color:#757575;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@lt.Name</div>
        }
    }
    else
    {
        <div style="font-weight:500;color:#2E7D32;white-space:nowrap">@(lt?.Name ?? "Ledig")</div>
    }

    @* Teacher avatar *@
    @if (ShowTeacherAvatars && teacher != null)
    {
        <div style="position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;
                    background-color:@teacher.Color;color:white;font-size:8px;font-weight:700;
                    display:flex;align-items:center;justify-content:center">
            @teacher.Initials
        </div>
    }
</div>

@code {
    [Inject] private BookingService BookingService { get; set; } = default!;

    [Parameter, EditorRequired] public BookingCalendarItem Item { get; set; } = default!;
    [Parameter] public bool ShowTeacherAvatars { get; set; }
}
