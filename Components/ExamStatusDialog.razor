@* Liten dialog för att uppdatera status på ett prov-event. *@
@using BookingDemo.Models

<MudDialog Style="max-width:420px;width:100%;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsTheory ? Icons.Material.Filled.MenuBook : Icons.Material.Filled.DirectionsCar)"
                     Class="mr-2" Style="vertical-align:middle" />
            @(IsTheory ? "Teoriprov" : "Praktiskt prov") @LicenseCategory
        </MudText>
    </TitleContent>

    <DialogContent>
        <div style="padding:4px 4px 12px">
            <div style="font-size:13px;color:#616161;margin-bottom:16px">
                Datum: <strong>@ExamDate.ToString("d MMM yyyy")</strong>
            </div>

            <div style="display:flex;flex-direction:column;gap:8px">
                @foreach (var (value, label, color, icon) in _options)
                {
                    var selected = _current == value;
                    <MudButton Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Default"
                               StartIcon="@icon"
                               FullWidth="true"
                               Style="@($"justify-content:flex-start;border-color:{color};color:{(selected ? "white" : color)};background:{(selected ? color : "transparent")}")"
                               OnClick="() => _current = value">
                        @label
                    </MudButton>
                }
            </div>
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Avbryt</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Spara</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public bool         IsTheory        { get; set; }
    [Parameter] public string       LicenseCategory { get; set; } = "";
    [Parameter] public DateTime     ExamDate        { get; set; }
    [Parameter] public ExamResult   Current         { get; set; } = ExamResult.Pending;

    private ExamResult _current;

    private readonly (ExamResult Value, string Label, string Color, string Icon)[] _options =
    {
        (ExamResult.Pending, "Väntar",      "#9e9e9e", Icons.Material.Filled.Schedule),
        (ExamResult.Passed,  "Godkänd",     "#2e7d32", Icons.Material.Filled.CheckCircle),
        (ExamResult.Failed,  "Ej godkänd",  "#c62828", Icons.Material.Filled.Cancel),
    };

    protected override void OnParametersSet() => _current = Current;

    private void Save()   => Dialog.Close(DialogResult.Ok(_current));
    private void Cancel() => Dialog.Cancel();
}
