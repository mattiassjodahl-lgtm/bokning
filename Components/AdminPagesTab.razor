@inject WebsiteService Web
@inject ISnackbar Snackbar

<MudGrid>
    @* ── Synliga sidor ─────────────────────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudText Typo="Typo.h6" GutterBottom="true">Synliga sidor</MudText>
        <MudText Typo="Typo.caption" Style="color:#666">Startsidan visas alltid. Övriga sidor kan döljas i menyn.</MudText>
        <div class="mt-3">
            @foreach (var (key, label) in Pages)
            {
                var k = key;
                <MudSwitch T="bool" Color="Color.Primary"
                           Value="@Web.Settings.PageVisibility.GetValueOrDefault(k, false)"
                           ValueChanged="@(v => Web.Settings.PageVisibility[k] = v)"
                           Label="@label" />
            }
        </div>
    </MudItem>

    @* ── Webbflaggade produkter (prislista) ────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudText Typo="Typo.h6" GutterBottom="true">Produkter i prislistan</MudText>
        <MudText Typo="Typo.caption" Style="color:#666">
            Bocka för de artiklar som ska visas publikt. @SelectedCount av @Web.AllArticles.Count valda.
        </MudText>
        <MudTextField @bind-Value="_prodSearch" @bind-Value:event="oninput" Immediate="true"
                      Placeholder="Sök artikel…" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mt-2 mb-1" Clearable="true" />

        @foreach (var cat in WebsiteService.ProductCategories)
        {
            var items = ArticlesIn(cat);
            if (items.Count == 0) continue;
            var allOn = items.All(a => IsFlagged(a.Id));
            var anyOn = items.Any(a => IsFlagged(a.Id));
            <div class="mt-2">
                <MudCheckBox T="bool" Dense="true" Color="Color.Primary"
                             Value="@allOn" Indeterminate="@(anyOn && !allOn)"
                             ValueChanged="@(v => SetGroup(items, v))">
                    <strong>@cat</strong> <span style="color:#888">(@items.Count(a => IsFlagged(a.Id))/@items.Count)</span>
                </MudCheckBox>
                <div style="margin-left:1.6rem">
                    @foreach (var a in items)
                    {
                        var id = a.Id;
                        <MudCheckBox T="bool" Dense="true"
                                     Value="@IsFlagged(id)"
                                     ValueChanged="@(v => ToggleArticle(id, v))"
                                     Label="@($"{a.ArticleNumber} – {a.Name}")" />
                    }
                </div>
            </div>
        }
    </MudItem>

    @* ── Profil ────────────────────────────────────────────────────────────── *@
    <MudItem xs="12">
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" GutterBottom="true">Körskolans profil</MudText>
    </MudItem>
    <MudItem xs="12" md="6"><MudTextField @bind-Value="Web.School.Name" Label="Namn" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12" md="3"><MudTextField @bind-Value="Web.School.LogoInitials" Label="Logo-initialer" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12" md="3"><MudTextField @bind-Value="Web.School.OrgNumber" Label="Org.nummer" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12" md="6"><MudTextField @bind-Value="Web.School.Tagline" Label="Slogan" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12" md="3"><MudTextField @bind-Value="Web.School.Phone" Label="Telefon" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12" md="3"><MudTextField @bind-Value="Web.School.Email" Label="E-post" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12" md="6"><MudTextField @bind-Value="Web.School.VisitAddress" Label="Besöksadress" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12" md="6"><MudTextField @bind-Value="Web.School.PostalAddress" Label="Postadress" Variant="Variant.Outlined" /></MudItem>

    <MudItem xs="12">
        <MudText Typo="Typo.subtitle2" GutterBottom="true">Logotyp</MudText>
        <AdminImageUpload Value="@Web.School.LogoImage"
                          ValueChanged="@(v => Web.School.LogoImage = v)"
                          Subfolder="logo"
                          Spec="SVG (vektorgrafik) rekommenderas – skarp i alla storlekar. Annars PNG med transparent bakgrund, höjd ca 48 px. Töm för att visa initialer istället." />
        @if (!string.IsNullOrEmpty(Web.School.LogoImage))
        {
            <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Clear" Class="mt-1"
                       OnClick="@(() => Web.School.LogoImage = "")">Ta bort logga (visa initialer)</MudButton>
        }
    </MudItem>

    @* ── STR (medlemskap) ──────────────────────────────────────────────────── *@
    <MudItem xs="12">
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.subtitle1" GutterBottom="true">STR-medlemskap (footer)</MudText>
    </MudItem>
    <MudItem xs="12" md="6"><MudTextField @bind-Value="Web.School.StrUrl" Label="STR-länk" Variant="Variant.Outlined" /></MudItem>
    <MudItem xs="12">
        <AdminImageUpload Value="@Web.School.StrLogo"
                          ValueChanged="@(v => Web.School.StrLogo = v)"
                          Subfolder="logo"
                          Spec="STR-logga (SVG/PNG). Töm för att visa ett textmärke 'STR' istället. Visas i footerns 'Medlem i'-block." />
        @if (!string.IsNullOrEmpty(Web.School.StrLogo))
        {
            <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Clear" Class="mt-1"
                       OnClick="@(() => Web.School.StrLogo = "")">Ta bort STR-logga</MudButton>
        }
    </MudItem>

    @* ── Öppettider ────────────────────────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">Öppettider</MudText>
        @foreach (var oh in Web.School.OpeningHours)
        {
            var row = oh;
            <div style="display:flex; gap:.5rem; align-items:center; margin-bottom:.5rem">
                <MudTextField @bind-Value="row.Days" Label="Dagar" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudTextField @bind-Value="row.Hours" Label="Tider" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               OnClick="@(() => Web.School.OpeningHours.Remove(row))" />
            </div>
        }
        <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                   OnClick="@(() => Web.School.OpeningHours.Add(new()))">Lägg till rad</MudButton>
    </MudItem>

    @* ── Sociala medier ────────────────────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">Sociala medier</MudText>
        @foreach (var soc in Web.School.Social)
        {
            var row = soc;
            <div style="display:flex; gap:.5rem; align-items:center; margin-bottom:.5rem">
                <MudSelect T="string" @bind-Value="row.Platform" Label="Plattform" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:130px">
                    <MudSelectItem T="string" Value="@("facebook")">Facebook</MudSelectItem>
                    <MudSelectItem T="string" Value="@("instagram")">Instagram</MudSelectItem>
                    <MudSelectItem T="string" Value="@("youtube")">YouTube</MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="row.Url" Label="Länk (URL)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               OnClick="@(() => Web.School.Social.Remove(row))" />
            </div>
        }
        <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                   OnClick="@(() => Web.School.Social.Add(new() { Platform = "facebook", Label = "Facebook" }))">Lägg till länk</MudButton>
    </MudItem>

    <MudItem xs="12">
        <MudDivider Class="my-4" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAll">Spara</MudButton>
    </MudItem>
</MudGrid>

@code {
    private static readonly (WebPageKey Key, string Label)[] Pages =
    {
        (WebPageKey.Ehandel,  "E-handel"),
        (WebPageKey.Kalender, "Bokningskalender"),
        (WebPageKey.Prislista, "Prislista"),
        (WebPageKey.Personal, "Anställda"),
        (WebPageKey.Nyheter,  "Nyheter"),
        (WebPageKey.Kontakt,  "Kontakta oss"),
    };

    private string _prodSearch = "";

    private bool IsFlagged(int id) => Web.Settings.WebFlaggedArticleIds.Contains(id);

    private int SelectedCount => Web.AllArticles.Count(a => IsFlagged(a.Id));

    private List<Article> ArticlesIn(string category) =>
        Web.AllArticles
            .Where(a => WebsiteService.ProductCategoryFor(a) == category)
            .Where(a => string.IsNullOrWhiteSpace(_prodSearch)
                || a.Name.Contains(_prodSearch, StringComparison.OrdinalIgnoreCase)
                || a.ArticleNumber.Contains(_prodSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private void SetGroup(IEnumerable<Article> items, bool on)
    {
        foreach (var a in items) ToggleArticle(a.Id, on);
    }

    private void ToggleArticle(int id, bool on)
    {
        var list = Web.Settings.WebFlaggedArticleIds;
        if (on) { if (!list.Contains(id)) list.Add(id); }
        else list.Remove(id);
    }

    private void SaveAll()
    {
        // Synka social-label med vald plattform.
        foreach (var s in Web.School.Social)
            s.Label = s.Platform switch { "facebook" => "Facebook", "instagram" => "Instagram", "youtube" => "YouTube", _ => s.Platform };
        Web.Save();
        Snackbar.Add("Inställningar sparade", Severity.Success);
    }
}
