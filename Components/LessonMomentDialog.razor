@* Dialog for selecting education plan moments to link to a booking. *@

<MudDialog Style="max-width:820px;width:100%;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="mr-2" Style="vertical-align:middle" />
            Lägg till utbildningsmoment
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="display:flex;gap:16px;min-height:400px;max-height:520px;">

            @* ── Left panel: currently selected moments ──────────────────────── *@
            <div style="flex:0 0 220px;border:1px solid #E0E0E0;border-radius:8px;display:flex;flex-direction:column;overflow:hidden;">
                <div style="padding:10px 12px;background:#F5F5F5;border-bottom:1px solid #E0E0E0;">
                    <MudText Typo="Typo.caption" Style="font-weight:600;text-transform:uppercase;color:#616161;">
                        Valda moment (@_selected.Count)
                    </MudText>
                </div>
                <div style="flex:1;overflow-y:auto;padding:8px;">
                    @if (_selected.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color:#9E9E9E;padding:8px 4px;">
                            Inga moment valda ännu.
                        </MudText>
                    }
                    else
                    {
                        @foreach (var gid in _selected)
                        {
                            var leftItem = FindItem(gid);
                            if (leftItem is null) continue;
                            var leftExisting = ExistingMoments.FirstOrDefault(m => m.GlobalId == gid);
                            <div style="display:flex;align-items:flex-start;gap:6px;padding:4px 2px;border-bottom:1px solid #F0F0F0;">
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Size="Size.Small"
                                               Style="padding:2px;margin-top:1px;color:#9E9E9E;"
                                               OnClick="@(() => ToggleItem(gid))" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:12px;line-height:1.3;word-break:break-word;">@leftItem.Title</div>
                                    @if (leftExisting is not null && leftExisting.Score > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Style="@LeftChipStyle(leftExisting.Score)">
                                            @leftExisting.StatusLabel
                                        </MudChip>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            @* ── Right panel: EduPlan tree ───────────────────────────────────── *@
            <div style="flex:1;border:1px solid #E0E0E0;border-radius:8px;display:flex;flex-direction:column;overflow:hidden;">
                <div style="padding:10px 12px;background:#F5F5F5;border-bottom:1px solid #E0E0E0;display:flex;align-items:center;gap:8px;">
                    <MudText Typo="Typo.caption" Style="font-weight:600;text-transform:uppercase;color:#616161;flex:1;">
                        @Plan.Title
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#9E9E9E;">
                        Välj moment att länka
                    </MudText>
                </div>
                <div style="flex:1;overflow-y:auto;">
                    @foreach (var sec in Plan.Sections)
                    {
                        var secItems     = sec.Items;
                        var allSelected  = secItems.All(i => _selected.Contains(i.GlobalId));
                        var someSelected = secItems.Any(i => _selected.Contains(i.GlobalId));

                        @* Section header with select-all checkbox *@
                        <div style="display:flex;align-items:center;padding:6px 12px;background:#FAFAFA;border-bottom:1px solid #EEEEEE;position:sticky;top:0;z-index:1;">
                            <MudCheckBox T="bool"
                                         Value="@allSelected"
                                         Indeterminate="@(someSelected && !allSelected)"
                                         ValueChanged="@((v) => ToggleSection(sec, v))"
                                         Size="Size.Small"
                                         Style="margin-right:4px;padding:2px;" />
                            <div>
                                @if (!string.IsNullOrEmpty(sec.Mark))
                                {
                                    <span style="font-size:11px;font-weight:700;color:#1565C0;margin-right:6px;">@(sec.Mark)</span>
                                }
                                <span style="font-size:13px;font-weight:600;color:#212121;">@(sec.Title)</span>
                            </div>
                        </div>

                        @* Items *@
                        @foreach (var item in secItems)
                        {
                            var isChecked    = _selected.Contains(item.GlobalId);
                            var rightExisting = ExistingMoments.FirstOrDefault(m => m.GlobalId == item.GlobalId);
                            <div style="@ItemDivStyle(isChecked)"
                                 @onclick="@(() => ToggleItem(item.GlobalId))">
                                <MudCheckBox T="bool"
                                             Value="@isChecked"
                                             Size="Size.Small"
                                             Style="margin-right:6px;padding:2px;pointer-events:none;" />
                                <div style="flex:1;min-width:0;padding-top:1px;">
                                    <span style="@(item.Done ? "font-size:13px;color:#4CAF50;" : "font-size:13px;")">
                                        @if (item.Done)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                     Style="font-size:13px;vertical-align:middle;color:#4CAF50;margin-right:3px;" />
                                        }
                                        @item.Title
                                    </span>
                                    @if (rightExisting is not null && rightExisting.Score > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Style="@RightChipStyle(rightExisting.Score)">
                                            @rightExisting.StatusLabel (@rightExisting.Score)
                                        </MudChip>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default">Avbryt</MudButton>
        <MudButton OnClick="Confirm" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Check">
            Spara (@_selected.Count valda)
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public EduPlan Plan { get; set; } = new();
    [Parameter] public List<LessonMoment> ExistingMoments { get; set; } = new();

    private HashSet<string> _selected = new();

    protected override void OnInitialized()
    {
        // Pre-select any already linked moments
        foreach (var m in ExistingMoments)
            _selected.Add(m.GlobalId);
    }

    private EduPlanItem? FindItem(string globalId)
    {
        foreach (var s in Plan.Sections)
            foreach (var item in s.Items)
                if (item.GlobalId == globalId) return item;
        return null;
    }

    private void ToggleItem(string globalId)
    {
        if (!_selected.Add(globalId))
            _selected.Remove(globalId);
    }

    private void ToggleSection(EduPlanSection sec, bool select)
    {
        foreach (var item in sec.Items)
        {
            if (select) _selected.Add(item.GlobalId);
            else        _selected.Remove(item.GlobalId);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Confirm()
    {
        // Build result: preserve existing moments (including scores/comments),
        // add new ones for freshly selected GlobalIds.
        var result = new List<LessonMoment>();
        foreach (var gid in _selected)
        {
            var existing = ExistingMoments.FirstOrDefault(m => m.GlobalId == gid);
            if (existing is not null)
            {
                result.Add(existing);
            }
            else
            {
                var item = FindItem(gid);
                result.Add(new LessonMoment
                {
                    GlobalId = gid,
                    Title    = item?.Title ?? gid,
                    Score    = 0,
                    Comment  = "",
                });
            }
        }
        MudDialog.Close(DialogResult.Ok(result));
    }

    // ── Style helpers (avoid nested quotes inside Razor HTML attributes) ─────

    private static string LeftChipStyle(int score) =>
        "margin-top:2px;height:18px;font-size:10px;color:white;background:" + StatusColor(score) + ";";

    private static string RightChipStyle(int score) =>
        "margin-left:6px;height:18px;font-size:10px;color:white;background:" + StatusColor(score) + ";";

    private static string ItemDivStyle(bool isChecked) =>
        "display:flex;align-items:flex-start;padding:5px 12px 5px 32px;border-bottom:1px solid #F5F5F5;cursor:pointer;" +
        (isChecked ? "background:#E3F2FD;" : "");

    private static string StatusColor(int score) => score switch
    {
        >= 3 => "#388E3C",
        > 0  => "#0097A7",
        _    => "#9E9E9E",
    };
}
