@inject BookingService BookingService
@inject IDialogService DialogService

@* ═══════════════════════════════════════════════════════════════════════════
   TeacherWeekView – lärare bredvid varandra (horisontell layout)
   Delar tidsaxel, upp till 6 lärare × 5-7 dagar sida vid sida.
   Scrollar horisontellt vid behov, vertikalt för tidslinje.
   ═══════════════════════════════════════════════════════════════════════════ *@

<div class="tcw-root">
    <div class="tcw-inner">

        @* ── Gemensam tidsaxel (sticky vänster) ─────────────────────────── *@
        <div class="tcw-gutter">
            @* Placeholder för lärarheader + dagheader *@
            <div style="height:@(TeacherHeaderH + DayHeaderH)px"></div>
            @* Timmarsetiketter *@
            <div style="position:relative; height:@(TotalHeight)px">
                @for (int h = StartHour; h <= EndHour; h++)
                {
                    var top = (h - StartHour) * PixelsPerHour;
                    <div class="tcw-time-label" style="top:@(top)px">@h:00</div>
                }
            </div>
        </div>

        @* ── Lärarsektioner sida vid sida ────────────────────────────────── *@
        <div class="tcw-sections">

            @foreach (var teacher in ActiveTeachers)
            {
                var t      = teacher;
                var events = GetEventsForTeacher(t.Id);
                var booked = events.Count(e => e.IsBooked);
                var avail  = events.Count(e => !e.IsBooked);

                <div class="tcw-section">

                    @* Lärarens rubrikrad (sticky top:0) *@
                    <div class="tcw-section-header" style="height:@(TeacherHeaderH)px">
                        <MudIcon Icon="@Icons.Material.Filled.Person"
                                 Style="font-size:14px; color:#546e7a; flex-shrink:0" />
                        <span class="tcw-teacher-name">@t.Name</span>
                        <span class="tcw-section-stats">@booked bokade&nbsp;·&nbsp;@avail lediga</span>
                    </div>

                    @* Dagkolumner *@
                    <div class="tcw-days">
                        @foreach (var day in DisplayDays)
                        {
                            var d       = day;
                            var dayEvts = events.Where(e => e.StartTime.Date == d.Date).ToList();
                            var isToday = d.Date == DateTime.Today.Date;

                            <div class="tcw-day-col">

                                @* Dagheader (sticky top:TeacherHeaderH) — format: 16/2 *@
                                <div class="tcw-day-header @(isToday ? "tcw-day-today" : "")"
                                     style="height:@(DayHeaderH)px; top:@(TeacherHeaderH)px">
                                    <span class="tcw-day-num">@d.Day/@d.Month</span>
                                </div>

                                @* Tidskolumn *@
                                <div class="tcw-day-body" style="height:@(TotalHeight)px">

                                    @* Timlinjer *@
                                    @for (int h = StartHour; h <= EndHour; h++)
                                    {
                                        var top = (h - StartHour) * PixelsPerHour;
                                        <div class="cal-gridline-hour" style="top:@(top)px"></div>
                                        @if (h < EndHour)
                                        {
                                            <div class="cal-gridline-half" style="top:@(top + PixelsPerHour / 2)px"></div>
                                        }
                                    }

                                    @* Droppbara 30-min slots (för drag-och-släpp av template-slots) *@
                                    @for (int h = StartHour; h < EndHour; h++)
                                    {
                                        for (int m = 0; m < 60; m += 30)
                                        {
                                            var dropH   = h;
                                            var dropM   = m;
                                            var dropTop = (h - StartHour) * PixelsPerHour + m * PixelsPerHour / 60;
                                            var dropDt  = d.Date.AddHours(dropH).AddMinutes(dropM);
                                            <div class="tcw-drop-slot"
                                                 style="top:@(dropTop)px; height:@(PixelsPerHour / 2)px"
                                                 @ondragover:preventDefault="true"
                                                 @ondrop="@(() => OnSlotDrop(t.Id, dropDt))">
                                            </div>
                                        }
                                    }

                                    @* Lediga pass (template-slots) *@
                                    @foreach (var evt in dayEvts.Where(e => !e.IsBooked))
                                    {
                                        var e      = evt;
                                        var topPx  = (e.StartTime.Hour - StartHour) * PixelsPerHour
                                                   + e.StartTime.Minute * PixelsPerHour / 60;
                                        var durMin = (e.EndTime - e.StartTime).TotalMinutes;
                                        var htPx   = Math.Max((int)(durMin * PixelsPerHour / 60), 14);
                                        var lt     = BookingService.LessonTypes.FirstOrDefault(l => l.Id == e.LessonTypeId);

                                        <div class="tcw-evt-available"
                                             style="top:@(topPx)px; height:@(htPx)px;
                                                    border-left-color:@(lt?.Color ?? "#4caf50")"
                                             draggable="true"
                                             @ondragstart="@(() => _draggingEvent = e)"
                                             @ondragend="@(() => _draggingEvent = null)"
                                             @onclick="@(() => OnAvailableSlotClick(t.Id, e))"
                                             title="@(lt?.Name ?? "Ledigt") @e.StartTime.ToString("HH:mm")–@e.EndTime.ToString("HH:mm") · dra för att flytta">
                                            <button class="cal-slot-delete-btn" title="Ta bort detta pass"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="@(() => DeleteTemplateSlot(e))">×</button>
                                            <span class="tcw-evt-label">@(lt?.Name ?? "Ledigt")</span>
                                            <span class="tcw-evt-time">@e.StartTime.ToString("HH:mm")</span>
                                        </div>
                                    }

                                    @* Bokade lektioner *@
                                    @foreach (var evt in dayEvts.Where(e => e.IsBooked))
                                    {
                                        var e      = evt;
                                        var topPx  = (e.StartTime.Hour - StartHour) * PixelsPerHour
                                                   + e.StartTime.Minute * PixelsPerHour / 60;
                                        var durMin = (e.EndTime - e.StartTime).TotalMinutes;
                                        var htPx   = Math.Max((int)(durMin * PixelsPerHour / 60), 14);
                                        var lt     = BookingService.LessonTypes.FirstOrDefault(l => l.Id == e.LessonTypeId);

                                        <div class="tcw-evt-booked @StudentFilterClass(e)"
                                             style="top:@(topPx)px; height:@(htPx)px;
                                                    background:@(lt?.LightColor ?? "#e3f2fd");
                                                    border-left-color:@(lt?.Color ?? "#1565c0")"
                                             @onclick="@(() => OnBookedEventClick(e))"
                                             title="@e.StudentName – @(lt?.Name) @e.StartTime.ToString("HH:mm")–@e.EndTime.ToString("HH:mm")">

                                            @if (htPx >= 32)
                                            {
                                                <div class="cal-event-time">
                                                    @e.StartTime.ToString("HH:mm")–@e.EndTime.ToString("HH:mm")
                                                </div>
                                            }
                                            @if (htPx >= 48)
                                            {
                                                @if (lt is { MaxStudents: > 1 })
                                                {
                                                    var bookedCount = e.AllStudentNames.Count();
                                                    var pct         = (double)bookedCount / lt.MaxStudents;
                                                    var badgeColor  = pct >= 0.9 ? "#f44336" : pct >= 0.5 ? "#ff9800" : "#4caf50";
                                                    <div class="cal-event-title">@lt.Name</div>
                                                    <div class="cal-capacity-badge" style="background-color:@badgeColor">
                                                        @bookedCount/@lt.MaxStudents
                                                    </div>
                                                }
                                                else if (e.ExtraStudents.Any())
                                                {
                                                    <div class="cal-event-title">
                                                        @e.StudentName
                                                        <span class="cal-event-shared-badge">+@e.ExtraStudents.Count</span>
                                                    </div>
                                                    @if (htPx >= 80)
                                                    {
                                                        @foreach (var s in e.ExtraStudents)
                                                        {
                                                            <div class="cal-event-sub">@s</div>
                                                        }
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="cal-event-title">@e.StudentName</div>
                                                }
                                                @if (lt is not { MaxStudents: > 1 } && lt != null && htPx >= 64)
                                                {
                                                    <div class="cal-event-sub">@lt.Name</div>
                                                }
                                            }
                                            else
                                            {
                                                <span class="tcw-evt-label">@e.StudentName</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    // ── Drag state för flytt av template-slots ────────────────────────────────
    private CalendarEvent? _draggingEvent;

    // ── Layoutkonstanter ──────────────────────────────────────────────────────
    private const int StartHour       = 7;
    private const int EndHour         = 20;
    private const int PixelsPerHour   = 50;
    private const int TeacherHeaderH  = 30;
    private const int DayHeaderH      = 32;
    private const int TotalHeight     = (EndHour - StartHour) * PixelsPerHour;

    private static readonly System.Globalization.CultureInfo _sv = new("sv-SE");

    // ── Parametrar ────────────────────────────────────────────────────────────

    /// <summary>Dagarna att visa (helgfiltrering redan gjord av Index.razor).</summary>
    [Parameter] public List<DateTime>  DisplayDays      { get; set; } = new();
    [Parameter] public CalendarFilter  Filter           { get; set; } = new();
    [Parameter] public List<Teacher>   ActiveTeachers   { get; set; } = new();
    [Parameter] public string          SelectedStudent  { get; set; } = "";
    [Parameter] public EventCallback   OnBookingChanged { get; set; }

    private string StudentFilterClass(CalendarEvent evt)
    {
        if (string.IsNullOrEmpty(SelectedStudent)) return "";
        if (!evt.IsBooked) return "";
        bool isMatch = evt.StudentName.Equals(SelectedStudent, StringComparison.OrdinalIgnoreCase)
                    || evt.ExtraStudents.Any(s => s.Equals(SelectedStudent, StringComparison.OrdinalIgnoreCase));
        return isMatch ? "cal-student-highlight" : "cal-student-dim";
    }

    // ── Datahämtning ──────────────────────────────────────────────────────────

    private List<CalendarEvent> GetEventsForTeacher(int teacherId)
    {
        if (!DisplayDays.Any()) return new();
        var start = DisplayDays.First().Date;
        var end   = DisplayDays.Last().Date.AddDays(1);

        var f = new CalendarFilter
        {
            ShowAvailable         = true,
            ShowBooked            = true,
            HideWeekends          = Filter.HideWeekends,
            HideTeacherAvatars    = Filter.HideTeacherAvatars,
            SelectedTeacherIds    = new List<int> { teacherId },
            SelectedLessonTypeIds = Filter.SelectedLessonTypeIds,
        };

        return BookingService.GetEventsForRange(start, end, f).ToList();
    }

    // ── Bokning ───────────────────────────────────────────────────────────────

    private async Task OnAvailableSlotClick(int teacherId, CalendarEvent slot)
    {
        var parameters = new DialogParameters<BookingDialog>
        {
            { x => x.PreselectedTeacherId,    teacherId         },
            { x => x.PreselectedStart,        slot.StartTime    },
            { x => x.PreselectedLessonTypeId, slot.LessonTypeId },
        };
        var dialog = await DialogService.ShowAsync<BookingDialog>(
            "Boka lektion", parameters,
            new DialogOptions { CloseOnEscapeKey = true, CloseButton = true });
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await OnBookingChanged.InvokeAsync();
            StateHasChanged();
        }
    }

    private async Task OnBookedEventClick(CalendarEvent evt)
    {
        var parameters = new DialogParameters<BookingDialog>
        {
            { x => x.ExistingEvent, evt },
        };
        var dialog = await DialogService.ShowAsync<BookingDialog>(
            "", parameters,
            new DialogOptions { CloseOnEscapeKey = true, CloseButton = true, MaxWidth = MaxWidth.Small });
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await OnBookingChanged.InvokeAsync();
            StateHasChanged();
        }
    }

    private void OnSlotDrop(int teacherId, DateTime slotTime)
    {
        if (_draggingEvent == null || _draggingEvent.TeacherId != teacherId) return;
        var evt           = _draggingEvent;
        _draggingEvent    = null;
        if (evt.LessonTypeId == null) return;

        var date          = DateOnly.FromDateTime(evt.StartTime);
        var originalStart = evt.TemplateOriginalStart ?? TimeOnly.FromDateTime(evt.StartTime);
        var newStart      = TimeOnly.FromDateTime(slotTime);

        BookingService.MoveTemplateSlot(evt.TeacherId, date, originalStart, evt.LessonTypeId.Value, newStart);
        StateHasChanged();
    }

    private void DeleteTemplateSlot(CalendarEvent evt)
    {
        if (evt.LessonTypeId == null) return;
        var date          = DateOnly.FromDateTime(evt.StartTime);
        var originalStart = evt.TemplateOriginalStart ?? TimeOnly.FromDateTime(evt.StartTime);
        BookingService.RemoveTemplateSlot(evt.TeacherId, date, originalStart, evt.LessonTypeId.Value);
        StateHasChanged();
    }
}
