@* Enkel dialog för att boka nytt prov (teori eller uppkörning) från elevkortet. *@
@inject BookingService BookingService

<MudDialog Style="max-width:440px;width:100%;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Class="mr-2" Style="vertical-align:middle" />
            Boka prov – @StudentName
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="3" Style="min-width:380px;padding:4px 0">

            @* Typ *@
            <MudSelect T="int" Label="Typ av prov"
                       Value="_lessonTypeId"
                       ValueChanged="@((int v) => _lessonTypeId = v)"
                       Required="true" Variant="Variant.Outlined">
                <MudSelectItem Value="10">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" />
                        <span>Teoriprov</span>
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="7">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Size="Size.Small" />
                        <span>Uppkörning</span>
                    </MudStack>
                </MudSelectItem>
            </MudSelect>

            @* Kategori *@
            <MudSelect T="string" Label="Körkortskategori"
                       Value="_licenseCategory"
                       ValueChanged="@((string v) => _licenseCategory = v)"
                       Required="true" Variant="Variant.Outlined">
                @foreach (var cat in _categories)
                {
                    <MudSelectItem T="string" Value="@cat">@cat</MudSelectItem>
                }
            </MudSelect>

            @* Datum *@
            <MudDatePicker Label="Datum" @bind-Date="_date"
                           MinDate="DateTime.Today"
                           Required="true" Variant="Variant.Outlined" />

            @* Tid *@
            <MudTimePicker Label="Starttid" @bind-Time="_startTime"
                           Required="true" Variant="Variant.Outlined" AmPm="false" />

            @* Lärare *@
            <MudSelect T="int" Label="Lärare"
                       Value="_teacherId"
                       ValueChanged="@((int v) => _teacherId = v)"
                       Variant="Variant.Outlined">
                <MudSelectItem Value="@0">Ingen lärare</MudSelectItem>
                @foreach (var t in BookingService.Teachers)
                {
                    <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem>
                }
            </MudSelect>

            @* Resurser (valfritt) *@
            <div>
                <MudText Typo="Typo.subtitle2" Class="mb-1">Resurser (valfritt)</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var res in BookingService.Resources)
                    {
                        var rid      = res.Id;
                        var selected = _selectedResourceIds.Contains(rid);
                        <MudChip T="string" Icon="@res.Icon" Size="Size.Small"
                                 Color="@(selected ? Color.Primary : Color.Default)"
                                 Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                                 OnClick="@(() => ToggleResource(rid))"
                                 Disabled="@(!res.IsAvailable)"
                                 Style="cursor:pointer">
                            @res.Name @(!res.IsAvailable ? " (ej tillgänglig)" : "")
                        </MudChip>
                    }
                </MudStack>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
            }

        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Avbryt</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@(!CanSave)"
                   OnClick="Save">
            Boka prov
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public string StudentName              { get; set; } = "";
    [Parameter] public IEnumerable<string>? Categories { get; set; }
    [Parameter] public string? PreselectedCategory     { get; set; }
    [Parameter] public int?    PreselectedLessonTypeId { get; set; }

    private int       _lessonTypeId    = 10;                 // default: teoriprov
    private string    _licenseCategory = "";
    private DateTime? _date            = DateTime.Today.AddDays(7);
    private TimeSpan? _startTime       = new(9, 0, 0);
    private int       _teacherId;
    private List<int> _selectedResourceIds = new();
    private string    _error = "";

    private List<string> _categories = new();

    private void ToggleResource(int resourceId)
    {
        if (_selectedResourceIds.Contains(resourceId))
            _selectedResourceIds.Remove(resourceId);
        else
            _selectedResourceIds.Add(resourceId);
    }

    private bool CanSave =>
        _date.HasValue
        && _startTime.HasValue
        && !string.IsNullOrWhiteSpace(_licenseCategory);

    protected override void OnInitialized()
    {
        _categories   = (Categories ?? new[] { "B" }).ToList();
        _licenseCategory = PreselectedCategory ?? _categories.FirstOrDefault() ?? "B";
        _lessonTypeId = PreselectedLessonTypeId ?? 10;
        _teacherId    = 0; // "Ingen lärare" default
    }

    private void Save()
    {
        _error = "";

        var start = _date!.Value.Date.Add(_startTime!.Value);
        var lt    = BookingService.GetLessonType(_lessonTypeId);
        var end   = start.AddMinutes(lt?.DefaultDurationMinutes ?? 50);

        // Krock-kontroll: lärare (hoppa över om "Ingen lärare")
        if (_teacherId > 0 && BookingService.HasEventConflict(_teacherId, start, end))
        {
            _error = "Läraren är redan bokad på denna tid.";
            return;
        }

        // Krock-kontroll: resurser
        if (_selectedResourceIds.Count > 0)
        {
            var clash = BookingService
                .GetBookedEventsWithAnyResource(_selectedResourceIds, start, end)
                .FirstOrDefault();
            if (clash != null)
            {
                var busyIds = clash.ResourceIds.Intersect(_selectedResourceIds).ToList();
                var names   = BookingService.GetResourcesById(busyIds).Select(r => r.Name);
                _error = $"Resurs upptagen på denna tid: {string.Join(", ", names)}.";
                return;
            }
        }

        var evt = BookingService.AddBooking(new BookingRequest
        {
            TeacherId           = _teacherId,
            StartTime           = start,
            EndTime             = end,
            StudentName         = StudentName,
            LessonTypeId        = _lessonTypeId,
            LicenseCategory     = _licenseCategory,
            SelectedResourceIds = _selectedResourceIds.ToList(),
        });

        Dialog.Close(DialogResult.Ok(evt));
    }

    private void Cancel() => Dialog.Cancel();
}
