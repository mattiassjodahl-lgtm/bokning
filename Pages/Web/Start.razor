@page "/webb"
@page "/webb/start"
@layout PublicLayout
@inject WebsiteService Web

<PageTitle>@Web.School.Name</PageTitle>

@{
    var s = Web.Settings;
    var layoutA = s.Layout == StartLayout.FocusNews;
}

@* ── Hero (full-bleed banner med bild över hela ytan) ─────────────────────── *@
<section class="ps-hero ps-section" style="background-image:url('@s.HeroImage')">
    <div class="ps-wrap ps-hero__inner">
        <h1>@s.HeroHeading</h1>
        <p>@s.HeroIngress</p>
        <div class="ps-hero__cta">
            <a class="ps-btn ps-btn--primary" href="@s.PrimaryCtaHref">@s.PrimaryCtaText</a>
            @* Andra CTA – endast i Layout B *@
            @if (!layoutA && !string.IsNullOrWhiteSpace(s.SecondaryCtaText))
            {
                <a class="ps-btn ps-btn--ghost" href="@s.SecondaryCtaHref">@s.SecondaryCtaText</a>
            }
        </div>
    </div>
</section>

@* ── Utbildningar (kort) ────────────────────────────────────────────────── *@
<section class="ps-section">
    <div class="ps-wrap">
        <h2>Våra utbildningar</h2>
        <div class="ps-grid @(layoutA ? "ps-grid--3" : "ps-grid--4") ps-mt">
            @* Layout A: tre kort + nyheter. Layout B: brett grid med alla kort. *@
            @{ var cards = (layoutA ? s.EducationCards.Take(3) : s.EducationCards).ToList(); }
            @for (var i = 0; i < cards.Count; i++)
            {
                var card = cards[i];
                <article class="ps-card ps-card--media @(card.HasPage ? "ps-card--link" : null)">
                    @if (card.HasPage)
                    {
                        <a class="ps-card__stretch" href="/webb/utbildning/@card.Slug"
                           aria-label="Läs mer om @card.Title"></a>
                    }
                    @if (!string.IsNullOrEmpty(card.Image))
                    {
                        <div class="ps-card__media ps-photo" role="img"
                             aria-label="@(string.IsNullOrWhiteSpace(card.ImageAlt) ? card.Title : card.ImageAlt)"
                             style="background-image:url('@card.Image')"></div>
                    }
                    else
                    {
                        <div class="ps-card__media ps-photo ps-photo--@((i % 4) + 1)">
                            <span class="material-icons" aria-hidden="true">@card.Icon</span>
                        </div>
                    }
                    <div class="ps-card__body">
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                        @if (card.HasPage)
                        {
                            <p class="ps-mt" style="margin:0;color:var(--ps-primary);font-weight:600">Läs mer →</p>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>

@* ── USP-band ───────────────────────────────────────────────────────────── *@
@if (s.ShowUsp && s.Usp.Count > 0)
{
    <section class="ps-section ps-usp">
        <div class="ps-wrap">
            <div class="ps-usp__grid">
                @foreach (var u in s.Usp)
                {
                    <div>
                        <span class="material-icons" aria-hidden="true">@u.Icon</span>
                        <h2 style="font-size:1.1rem">@u.Title</h2>
                        <p>@u.Text</p>
                    </div>
                }
            </div>
        </div>
    </section>
}

@* ── Nyheter ─────────────────────────────────────────────────────────────── *@
@if (s.ShowNews && s.News.Count > 0)
{
    <section class="ps-section ps-section--soft ps-news">
        <div class="ps-wrap">
            <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;flex-wrap:wrap">
                <h2>Nyheter</h2>
                <a href="/webb/nyheter" style="font-weight:600">Alla nyheter →</a>
            </div>
            <div class="ps-grid ps-grid--3 ps-mt">
                @foreach (var n in s.News.Take(3))
                {
                    <article class="ps-card ps-card--media ps-card--link">
                        <a class="ps-card__stretch" href="/webb/nyheter/@n.Slug" aria-label="Läs nyheten: @n.Title"></a>
                        @if (!string.IsNullOrEmpty(n.Image))
                        {
                            <div class="ps-card__media ps-photo" role="img"
                                 aria-label="@(string.IsNullOrWhiteSpace(n.ImageAlt) ? n.Title : n.ImageAlt)"
                                 style="background-image:url('@n.Image')"></div>
                        }
                        <div class="ps-card__body">
                            <time datetime="@n.Date.ToString("yyyy-MM-dd")">@n.Date.ToString("d MMMM yyyy", Sv)</time>
                            <h3>@n.Title</h3>
                            <p>@n.Summary</p>
                            <p class="ps-mt" style="margin:0;color:var(--ps-primary);font-weight:600">Läs mer →</p>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
}

@* ── Så går det till (steg-guide) ───────────────────────────────────────── *@
@if (s.ShowSteps && s.Steps.Count > 0)
{
    <section class="ps-section">
        <div class="ps-wrap">
            <h2>@s.StepsHeading</h2>
            <ol class="ps-steps ps-mt">
                @for (var i = 0; i < s.Steps.Count; i++)
                {
                    var step = s.Steps[i];
                    <li class="ps-step">
                        <div class="ps-step__num" aria-hidden="true">@(i + 1)</div>
                        <h3>@step.Title</h3>
                        <p>@step.Text</p>
                    </li>
                }
            </ol>
        </div>
    </section>
}

@* ── Kommande kurser ────────────────────────────────────────────────────── *@
@if (s.ShowCourses && s.Courses.Count > 0)
{
    <section class="ps-section ps-section--soft">
        <div class="ps-wrap">
            <h2>Kommande kurser</h2>
            <div class="ps-table-wrap ps-mt">
                <table class="ps-table">
                    <caption>Kursstarter de närmaste månaderna</caption>
                    <thead>
                        <tr><th scope="col">Start</th><th scope="col">Kurs</th><th scope="col">Pris</th><th scope="col">Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var k in s.Courses.OrderBy(c => c.Date))
                        {
                            <tr>
                                <td>@k.Date.ToString("d MMM yyyy", Sv)</td>
                                <td>@k.Name</td>
                                <td class="ps-price">@k.Price.ToString("N0", Sv) kr</td>
                                <td>
                                    @if (k.Full)
                                    {
                                        <span class="ps-badge ps-badge--full"><span class="material-icons" aria-hidden="true" style="font-size:16px">block</span> Fullt</span>
                                    }
                                    else
                                    {
                                        <span class="ps-badge ps-badge--open"><span class="material-icons" aria-hidden="true" style="font-size:16px">event_available</span> Platser kvar</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}

@code {
    private static readonly System.Globalization.CultureInfo Sv = new("sv-SE");
}
