@page "/webb"
@page "/webb/start"
@layout PublicLayout
@inject WebsiteService Web

<PageTitle>@Web.School.Name</PageTitle>

@{
    var s = Web.Settings;
    var layoutA = s.Layout == StartLayout.FocusNews;
}

@* ── Hero (full-bleed banner med bild över hela ytan) ─────────────────────── *@
<section class="ps-hero ps-section" style="background-image:url('@s.HeroImage')">
    <div class="ps-wrap ps-hero__inner">
        <h1>@s.HeroHeading</h1>
        <p>@s.HeroIngress</p>
        <div class="ps-hero__cta">
            <a class="ps-btn ps-btn--primary" href="@s.PrimaryCtaHref">@s.PrimaryCtaText</a>
            @* Andra CTA – endast i Layout B *@
            @if (!layoutA && !string.IsNullOrWhiteSpace(s.SecondaryCtaText))
            {
                <a class="ps-btn ps-btn--ghost" href="@s.SecondaryCtaHref">@s.SecondaryCtaText</a>
            }
        </div>
    </div>
</section>

@* ── Utbildningar (kort) ────────────────────────────────────────────────── *@
<section class="ps-section">
    <div class="ps-wrap">
        <h2>Våra utbildningar</h2>
        <div class="ps-grid @(layoutA ? "ps-grid--3" : "ps-grid--4") ps-mt">
            @* Layout A: tre kort + nyheter. Layout B: brett grid med alla kort. *@
            @{ var cards = (layoutA ? s.EducationCards.Take(3) : s.EducationCards).ToList(); }
            @for (var i = 0; i < cards.Count; i++)
            {
                var card = cards[i];
                <article class="ps-card ps-card--media @(card.HasPage ? "ps-card--link" : null)">
                    @if (card.HasPage)
                    {
                        <a class="ps-card__stretch" href="/webb/utbildning/@card.Slug"
                           aria-label="Läs mer om @card.Title"></a>
                    }
                    @if (!string.IsNullOrEmpty(card.Image))
                    {
                        <div class="ps-card__media ps-photo" role="img" aria-label="@card.Title"
                             style="background-image:url('@card.Image')"></div>
                    }
                    else
                    {
                        <div class="ps-card__media ps-photo ps-photo--@((i % 4) + 1)">
                            <span class="material-icons" aria-hidden="true">@card.Icon</span>
                        </div>
                    }
                    <div class="ps-card__body">
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                        @if (card.HasPage)
                        {
                            <p class="ps-mt" style="margin:0;color:var(--ps-primary);font-weight:600">Läs mer →</p>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>

@* ── USP-band ───────────────────────────────────────────────────────────── *@
<section class="ps-section ps-usp">
    <div class="ps-wrap">
        <div class="ps-usp__grid">
            <div>
                <span class="material-icons" aria-hidden="true">verified</span>
                <h2 style="font-size:1.1rem">Ansluten till STR</h2>
                <p>Kvalitetssäkrad utbildning enligt STR:s krav.</p>
            </div>
            <div>
                <span class="material-icons" aria-hidden="true">school</span>
                <h2 style="font-size:1.1rem">Erfarna lärare</h2>
                <p>Behöriga trafiklärare med lång erfarenhet.</p>
            </div>
            <div>
                <span class="material-icons" aria-hidden="true">directions_car</span>
                <h2 style="font-size:1.1rem">Moderna bilar</h2>
                <p>Manuellt och automat – trygga, nya fordon.</p>
            </div>
            <div>
                <span class="material-icons" aria-hidden="true">thumb_up</span>
                <h2 style="font-size:1.1rem">Hög andel godkända</h2>
                <p>Vi förbereder dig hela vägen till uppkörningen.</p>
            </div>
        </div>
    </div>
</section>

@* ── Nyheter – endast Layout A ──────────────────────────────────────────── *@
@if (layoutA)
{
    <section class="ps-section ps-section--soft ps-news">
        <div class="ps-wrap">
            <h2>Nyheter</h2>
            <div class="ps-grid ps-grid--3 ps-mt">
                @foreach (var n in s.News)
                {
                    <article class="ps-card">
                        <time datetime="@n.Date.ToString("yyyy-MM-dd")">@n.Date.ToString("d MMMM yyyy", Sv)</time>
                        <h3>@n.Title</h3>
                        <p>@n.Body</p>
                    </article>
                }
            </div>
        </div>
    </section>
}

@* ── Så går det till (steg-guide) ───────────────────────────────────────── *@
<section class="ps-section">
    <div class="ps-wrap">
        <h2>Så tar du körkort – fyra enkla steg</h2>
        <ol class="ps-steps ps-mt">
            <li class="ps-step">
                <div class="ps-step__num" aria-hidden="true">1</div>
                <h3>Boka introduktion</h3>
                <p>Vi går igenom dina mål och lägger upp en plan som passar dig.</p>
            </li>
            <li class="ps-step">
                <div class="ps-step__num" aria-hidden="true">2</div>
                <h3>Övningskör</h3>
                <p>Körlektioner i din takt, varvat med teori och riskutbildning.</p>
            </li>
            <li class="ps-step">
                <div class="ps-step__num" aria-hidden="true">3</div>
                <h3>Risk 1 &amp; 2</h3>
                <p>Obligatorisk riskutbildning – halkbana och trafiksäkerhet.</p>
            </li>
            <li class="ps-step">
                <div class="ps-step__num" aria-hidden="true">4</div>
                <h3>Prov &amp; körkort</h3>
                <p>Vi förbereder dig inför kunskapsprov och uppkörning.</p>
            </li>
        </ol>
    </div>
</section>

@* ── Kommande kurser ────────────────────────────────────────────────────── *@
<section class="ps-section @(layoutA ? "" : "ps-section--soft")">
    <div class="ps-wrap">
        <h2>Kommande kurser</h2>
        <div class="ps-table-wrap ps-mt">
            <table class="ps-table">
                <caption>Kursstarter de närmaste månaderna</caption>
                <thead>
                    <tr><th scope="col">Start</th><th scope="col">Kurs</th><th scope="col">Pris</th><th scope="col">Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var k in UpcomingCourses)
                    {
                        <tr>
                            <td>@k.Start.ToString("d MMM yyyy", Sv)</td>
                            <td>@k.Name</td>
                            <td class="ps-price">@k.Price.ToString("N0", Sv) kr</td>
                            <td>
                                @if (k.Full)
                                {
                                    <span class="ps-badge ps-badge--full"><span class="material-icons" aria-hidden="true" style="font-size:16px">block</span> Fullt</span>
                                }
                                else
                                {
                                    <span class="ps-badge ps-badge--open"><span class="material-icons" aria-hidden="true" style="font-size:16px">event_available</span> Platser kvar</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@code {
    private static readonly System.Globalization.CultureInfo Sv = new("sv-SE");

    private record Course(DateTime Start, string Name, decimal Price, bool Full);

    // Mockade kursstarter (motsvarar "Kommande kurser" på exempelsajterna).
    private static readonly Course[] UpcomingCourses =
    {
        new(new DateTime(2026, 7, 2),  "Moped AM",            9995, false),
        new(new DateTime(2026, 7, 6),  "Riskutbildning 2 MC", 3800, true),
        new(new DateTime(2026, 7, 14), "Handledarutbildning",  550, false),
        new(new DateTime(2026, 8, 10), "Intensivkurs B",     14900, false),
    };
}
