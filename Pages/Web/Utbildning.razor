@page "/webb/utbildning/{Slug}"
@layout PublicLayout
@inject WebsiteService Web

<PageTitle>@(_edu?.Title ?? "Utbildning") – @Web.School.Name</PageTitle>

@if (_edu is null)
{
    <section class="ps-section">
        <div class="ps-wrap">
            <h1>Utbildningen hittades inte</h1>
            <p class="ps-lead">Sidan du letar efter finns inte. Gå tillbaka till <a href="/webb/start">startsidan</a>.</p>
        </div>
    </section>
}
else
{
    @* ── Sub-hero med utbildningens bild ──────────────────────────────────── *@
    <section class="ps-hero ps-hero--sub ps-section" style="background-image:url('@_edu.Image')">
        <div class="ps-wrap ps-hero__inner">
            <p style="margin:0 0 .25rem;color:#dfeaf4;font-weight:600">Utbildning</p>
            <h1>@_edu.Title</h1>
            <p>@_edu.Description</p>
        </div>
    </section>

    @* ── Innehåll (fast mall) ─────────────────────────────────────────────── *@
    <section class="ps-section">
        <div class="ps-wrap" style="max-width: 820px">
            <p class="ps-lead">@_edu.LongText</p>

            @if (_edu.Highlights.Count > 0)
            {
                <h2>Det här ingår</h2>
                <ul class="ps-checklist">
                    @foreach (var h in _edu.Highlights)
                    {
                        <li>@h</li>
                    }
                </ul>
            }

            @if (!string.IsNullOrEmpty(_edu.PriceFrom))
            {
                <p class="ps-price" style="font-size:1.25rem;color:var(--ps-ink)">@_edu.PriceFrom</p>
            }

            <div class="ps-hero__cta ps-mt">
                <a class="ps-btn ps-btn--primary" href="/webb/kalender">Boka tid</a>
                <a class="ps-btn ps-btn--outline" href="/webb/kontakt">Kontakta oss</a>
            </div>

            <p class="ps-mt"><a href="/webb/start">← Tillbaka till startsidan</a></p>
        </div>
    </section>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private EducationCard? _edu;

    protected override void OnParametersSet() => _edu = Web.GetEducation(Slug);
}
