@page "/elevkort/{StudentName}"
@inject BookingService BookingService
@inject IDialogService DialogService

<PageTitle>Elevkort – @StudentName</PageTitle>

@if (_profile == null)
{
    <div style="padding:32px">
        <MudAlert Severity="Severity.Warning">Eleven hittades inte.</MudAlert>
    </div>
}
else
{
    <div class="sc-fullscreen">

        @* ── Tabs full-width ──────────────────────────────────────────────── *@
        <div style="flex:1;overflow-y:auto">
                <MudTabs Elevation="2" Rounded="false"
                         PanelClass="pa-4" Color="Color.Primary" Style="width:100%">

                    @* ── Tab 1: Översikt ───────────────────────────────────── *@
                    <MudTabPanel Text="Översikt" Icon="@Icons.Material.Filled.Person">

                        @* ── 3-column Översikt layout ─────────────────────────────── *@
                        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;align-items:start;width:100%">

                            @* ── Kolumn 1: Elevinfo ──────────────────────────────── *@
                            <div style="min-width:0;background:white;border:1px solid @(_editMode?"#1565C0":"#e8e8e8");border-radius:12px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.06)">

                                @* Kort-rubrik + redigera-knapp *@
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
                                    <div style="font-size:10px;font-weight:700;color:#9e9e9e;text-transform:uppercase;letter-spacing:.07em">Elevinfo</div>
                                    @if (!_editMode)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                       Size="Size.Small"
                                                       Style="color:#9e9e9e;margin:-6px -6px -6px 0"
                                                       OnClick="StartEdit" />
                                    }
                                </div>

                                @* Foto + namn + behörighetschips *@
                                <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
                                    <MudAvatar Style="width:56px;height:56px;font-size:1.4rem;border:3px solid #e8e8e8;flex-shrink:0">
                                        <MudImage Src="@_profile.PhotoUrl" Alt="Foto" />
                                    </MudAvatar>
                                    <div>
                                        <div style="font-size:16px;font-weight:700;color:#1a1a1a;line-height:1.2;margin-bottom:5px">@_profile.Name</div>
                                        <div style="display:flex;flex-wrap:wrap;gap:4px">
                                            @foreach (var lc in _profile.LicenseCategories)
                                            {
                                                <span style="font-size:11px;padding:2px 8px;border-radius:10px;background:#e3f2fd;color:#1565C0;font-weight:600">@lc</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                @* ── LÄSLÄGE ──────────────────────────────────────── *@
                                @if (!_editMode)
                                {
                                    <div style="display:flex;flex-direction:column;gap:11px;border-top:1px solid #f0f0f0;padding-top:14px">

                                        <div style="display:flex;align-items:flex-start;gap:10px">
                                            <MudIcon Icon="@Icons.Material.Filled.Badge" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                            <div>
                                                <div style="font-size:10px;color:#9e9e9e;margin-bottom:1px;text-transform:uppercase;letter-spacing:.04em">Tilltalsnamn</div>
                                                <div style="font-size:13px;font-weight:700;color:#1a1a1a">@_profile.NickName</div>
                                            </div>
                                        </div>

                                        <div style="display:flex;align-items:flex-start;gap:10px">
                                            <MudIcon Icon="@Icons.Material.Filled.Cake" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                            <div>
                                                <div style="font-size:10px;color:#9e9e9e;margin-bottom:1px;text-transform:uppercase;letter-spacing:.04em">Ålder &amp; kön</div>
                                                <div style="font-size:13px;font-weight:700;color:#1a1a1a">@_profile.Age år · @_profile.Gender</div>
                                            </div>
                                        </div>

                                        <div style="display:flex;align-items:flex-start;gap:10px">
                                            <MudIcon Icon="@Icons.Material.Filled.Home" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                            <div>
                                                <div style="font-size:10px;color:#9e9e9e;margin-bottom:1px;text-transform:uppercase;letter-spacing:.04em">Adress</div>
                                                <div style="font-size:13px;font-weight:700;color:#1a1a1a">@_profile.Address</div>
                                            </div>
                                        </div>

                                        <div style="display:flex;align-items:flex-start;gap:10px">
                                            <MudIcon Icon="@Icons.Material.Filled.Email" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                            <div>
                                                <div style="font-size:10px;color:#9e9e9e;margin-bottom:1px;text-transform:uppercase;letter-spacing:.04em">E-post</div>
                                                <MudLink Href="@($"mailto:{_profile.Email}")" Style="font-size:13px;font-weight:700">@_profile.Email</MudLink>
                                            </div>
                                        </div>

                                        <div style="display:flex;align-items:flex-start;gap:10px">
                                            <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                            <div>
                                                <div style="font-size:10px;color:#9e9e9e;margin-bottom:1px;text-transform:uppercase;letter-spacing:.04em">Mobil</div>
                                                <MudLink Href="@($"tel:{_profile.Phone.Replace(" ","").Replace("-","")}")" Style="font-size:13px;font-weight:700">@_profile.Phone</MudLink>
                                            </div>
                                        </div>

                                        <div style="display:flex;align-items:flex-start;gap:10px">
                                            <MudIcon Icon="@Icons.Material.Filled.Sms" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                            <div>
                                                <div style="font-size:10px;color:#9e9e9e;margin-bottom:1px;text-transform:uppercase;letter-spacing:.04em">SMS-påminnelse</div>
                                                <div style="font-size:13px;font-weight:700;color:@(_profile.SmsReminder ? "#2e7d32" : "#c62828")">
                                                    @(_profile.SmsReminder ? "Ja" : "Nej")
                                                </div>
                                            </div>
                                        </div>

                                        <div style="display:flex;align-items:flex-start;gap:10px">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                            <div>
                                                <div style="font-size:10px;color:#9e9e9e;margin-bottom:1px;text-transform:uppercase;letter-spacing:.04em">Skapad</div>
                                                <div style="font-size:13px;font-weight:700;color:#1a1a1a">@_profile.CreatedAt.ToString("d MMM yyyy") · @_profile.CreatedFrom</div>
                                            </div>
                                        </div>

                                        @if (_profile.ContactPersons.Count > 0)
                                        {
                                            <div style="display:flex;align-items:flex-start;gap:10px">
                                                <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Style="font-size:16px;color:#bdbdbd;margin-top:1px;flex-shrink:0" />
                                                <div>
                                                    <div style="font-size:10px;color:#9e9e9e;margin-bottom:4px;text-transform:uppercase;letter-spacing:.04em">Kontaktpersoner</div>
                                                    @foreach (var cp in _profile.ContactPersons)
                                                    {
                                                        <div style="margin-bottom:5px">
                                                            <MudLink Href="@($"/elevkort/{Uri.EscapeDataString(cp.Name)}")" Style="font-size:13px;font-weight:700;color:#1565C0;text-decoration:none">@cp.Name</MudLink>
                                                            <div style="font-size:11px;color:#757575">@cp.Relation ·
                                                                <MudLink Href="@($"tel:{cp.Phone.Replace(" ","").Replace("-","")}")" Style="font-size:11px">@cp.Phone</MudLink>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }

                                    </div>
                                }

                                @* ── REDIGERINGSLÄGE ──────────────────────────────── *@
                                else
                                {
                                    <div style="display:flex;flex-direction:column;gap:12px;border-top:1px solid #f0f0f0;padding-top:14px">

                                        <MudTextField @bind-Value="_editNickName"  Label="Tilltalsnamn" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        <MudTextField @bind-Value="_editEmail"     Label="E-post"       Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Email" />
                                        <MudTextField @bind-Value="_editPhone"     Label="Mobil"        Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Telephone" />
                                        <MudTextField @bind-Value="_editAddress"   Label="Adress"       Variant="Variant.Outlined" Margin="Margin.Dense" />

                                        <div style="display:flex;gap:8px">
                                            <MudTextField @bind-Value="_editAge"   Label="Ålder" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Number" Style="flex:1" />
                                            <MudSelect   @bind-Value="_editGender" Label="Kön"   Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1">
                                                <MudSelectItem Value="@("Man")">Man</MudSelectItem>
                                                <MudSelectItem Value="@("Kvinna")">Kvinna</MudSelectItem>
                                                <MudSelectItem Value="@("Annat")">Annat</MudSelectItem>
                                            </MudSelect>
                                        </div>

                                        <MudCheckBox @bind-Value="_editSmsReminder" Label="SMS-påminnelse" Color="Color.Primary" Dense="true" />

                                        @* Kontaktpersoner *@
                                        <div>
                                            <div style="font-size:10px;color:#9e9e9e;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">Kontaktpersoner</div>
                                            @for (int ci = 0; ci < _editContacts.Count; ci++)
                                            {
                                                var idx = ci;
                                                <div style="border:1px solid #e8e8e8;border-radius:8px;padding:10px;margin-bottom:8px;position:relative">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                                   Style="position:absolute;top:4px;right:4px;color:#bdbdbd"
                                                                   OnClick="() => _editContacts.RemoveAt(idx)" />
                                                    <div style="display:flex;flex-direction:column;gap:6px;padding-right:28px">
                                                        <MudTextField Value="@_editContacts[idx].Name"
                                                                      ValueChanged="@((string v) => _editContacts[idx].Name = v)"
                                                                      Label="Namn" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                                        <div style="display:flex;gap:6px">
                                                            <MudTextField Value="@_editContacts[idx].Relation"
                                                                          ValueChanged="@((string v) => _editContacts[idx].Relation = v)"
                                                                          Label="Relation" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1" />
                                                            <MudTextField Value="@_editContacts[idx].Phone"
                                                                          ValueChanged="@((string v) => _editContacts[idx].Phone = v)"
                                                                          Label="Telefon" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1"
                                                                          InputType="InputType.Telephone" />
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            <MudButton StartIcon="@Icons.Material.Filled.Add"
                                                       Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="AddEditContact">Lägg till kontaktperson</MudButton>
                                        </div>

                                        @* Spara / Avbryt *@
                                        <div style="display:flex;gap:8px;margin-top:4px">
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SaveEdit">Spara</MudButton>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" OnClick="CancelEdit">Avbryt</MudButton>
                                        </div>

                                    </div>
                                }

                            </div>

                            @* ── Kolumn 2: Status på prov + Status praktik & teori ── *@
                            <div style="min-width:0;display:flex;flex-direction:column;gap:20px">

                                @* ── Status på prov (hämtas från kalenderhändelser) ── *@
                                <div style="background:white;border:1px solid #e8e8e8;border-radius:12px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.06)">
                                    <div style="font-size:10px;font-weight:700;color:#9e9e9e;text-transform:uppercase;letter-spacing:.07em;margin-bottom:14px">Status på prov</div>

                                    @foreach (var lc in _profile.LicenseCategories)
                                    {
                                        var theoryEvents    = BookingService.GetExamEvents(_profile.Name, lc, theory: true).ToList();
                                        var practicalEvents = BookingService.GetExamEvents(_profile.Name, lc, theory: false).ToList();

                                        <div style="margin-bottom:12px">
                                            <span style="font-size:12px;font-weight:700;color:#1a1a1a">@lc</span>

                                            @* Teoriprov: en rad per bokat prov + rad för att boka nytt *@
                                            @foreach (var ev in theoryEvents)
                                            {
                                                var d = ExamDisplay(ev);
                                                <div style="display:flex;align-items:center;gap:8px;margin-top:6px;padding:4px 6px;border-radius:6px;cursor:pointer"
                                                     @onclick="@(async () => await OpenExamDialog(ev, isTheory: true, lc))"
                                                     title="Klicka för att uppdatera status">
                                                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="font-size:16px;color:#bdbdbd;flex-shrink:0" />
                                                    <div style="flex:1">
                                                        <div style="font-size:10px;color:#9e9e9e;text-transform:uppercase;letter-spacing:.04em">Teoriprov</div>
                                                        <div style="@($"font-size:13px;font-weight:700;color:{d.Color}")">
                                                            @d.Label · @ev.StartTime.ToString("d MMM yyyy")
                                                        </div>
                                                    </div>
                                                    <MudIcon Icon="@d.Icon" Style="@($"font-size:20px;color:{d.Color}")" />
                                                </div>
                                            }
                                            <div style="display:flex;align-items:center;gap:8px;margin-top:6px;padding:4px 6px;border-radius:6px;cursor:pointer"
                                                 @onclick="@(async () => await BookNewExam(isTheory: true, lc))"
                                                 title="Klicka för att boka teoriprov">
                                                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="font-size:16px;color:#bdbdbd;flex-shrink:0" />
                                                <div style="flex:1">
                                                    <div style="font-size:10px;color:#9e9e9e;text-transform:uppercase;letter-spacing:.04em">Teoriprov</div>
                                                    <div style="font-size:13px;font-weight:700;color:#9e9e9e">Boka teoriprov</div>
                                                </div>
                                                <MudIcon Icon="@Icons.Material.Filled.AddCircleOutline" Style="font-size:20px;color:#9e9e9e" />
                                            </div>

                                            @* Uppkörning: en rad per bokat prov + rad för att boka nytt *@
                                            @foreach (var ev in practicalEvents)
                                            {
                                                var d = ExamDisplay(ev);
                                                <div style="display:flex;align-items:center;gap:8px;margin-top:6px;padding:4px 6px;border-radius:6px;cursor:pointer"
                                                     @onclick="@(async () => await OpenExamDialog(ev, isTheory: false, lc))"
                                                     title="Klicka för att uppdatera status">
                                                    <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Style="font-size:16px;color:#bdbdbd;flex-shrink:0" />
                                                    <div style="flex:1">
                                                        <div style="font-size:10px;color:#9e9e9e;text-transform:uppercase;letter-spacing:.04em">Praktiskt prov</div>
                                                        <div style="@($"font-size:13px;font-weight:700;color:{d.Color}")">
                                                            @d.Label · @ev.StartTime.ToString("d MMM yyyy")
                                                        </div>
                                                    </div>
                                                    <MudIcon Icon="@d.Icon" Style="@($"font-size:20px;color:{d.Color}")" />
                                                </div>
                                            }
                                            <div style="display:flex;align-items:center;gap:8px;margin-top:6px;padding:4px 6px;border-radius:6px;cursor:pointer"
                                                 @onclick="@(async () => await BookNewExam(isTheory: false, lc))"
                                                 title="Klicka för att boka uppkörning">
                                                <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Style="font-size:16px;color:#bdbdbd;flex-shrink:0" />
                                                <div style="flex:1">
                                                    <div style="font-size:10px;color:#9e9e9e;text-transform:uppercase;letter-spacing:.04em">Praktiskt prov</div>
                                                    <div style="font-size:13px;font-weight:700;color:#9e9e9e">Boka uppkörning</div>
                                                </div>
                                                <MudIcon Icon="@Icons.Material.Filled.AddCircleOutline" Style="font-size:20px;color:#9e9e9e" />
                                            </div>
                                        </div>
                                    }
                                </div>

                                <StatusPerLicense Profile="_profile" />
                            </div>

                            @* ── Kolumn 3: Kommentarer ──────────────────────────── *@
                            <div style="min-width:0;background:white;border:1px solid #e8e8e8;border-radius:12px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.06);display:flex;flex-direction:column">

                                <div style="font-size:10px;font-weight:700;color:#9e9e9e;text-transform:uppercase;letter-spacing:.07em;margin-bottom:14px">Kommentarer</div>

                                @* Befintliga kommentarer *@
                                @if (_studentNotes.Count == 0)
                                {
                                    <div style="color:#9e9e9e;font-size:13px;padding:8px 0">Inga kommentarer ännu.</div>
                                }
                                else
                                {
                                    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:14px;max-height:400px;overflow-y:auto">
                                        @foreach (var note in _studentNotes)
                                        {
                                            <div style="border-left:3px solid #1565C0;padding:8px 12px;background:#fafafa;border-radius:0 8px 8px 0">
                                                <div style="font-size:13px;color:#1a1a1a;white-space:pre-wrap;word-break:break-word">@note.Text</div>
                                                <div style="font-size:11px;color:#9e9e9e;margin-top:4px">
                                                    @note.Author · @note.CreatedAt.ToString("d MMM yyyy HH:mm")
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                @* Ny kommentar *@
                                <div style="margin-top:auto">
                                    <MudTextField @bind-Value="_newNoteText"
                                                  Label="Skriv en kommentar…"
                                                  Lines="2"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense" />
                                    <div style="display:flex;justify-content:flex-end;margin-top:6px">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Send"
                                                   Disabled="@string.IsNullOrWhiteSpace(_newNoteText)"
                                                   OnClick="AddStudentNote">
                                            Spara
                                        </MudButton>
                                    </div>
                                </div>

                            </div>

                        </div>

                    </MudTabPanel>

                    @* ── Tab 4: Utbildning ────────────────────────────────────── *@
                    <MudTabPanel Text="Utbildning" Icon="@Icons.Material.Filled.School">

                        @* ── Framtida timmar ────────────────────────────────────────── *@
                        <div style="margin-bottom:16px">
                            <div style="font-size:11px;font-weight:700;color:#757575;text-transform:uppercase;letter-spacing:.06em;padding:6px 0 6px 2px;border-bottom:2px solid #E0E0E0;margin-bottom:6px">
                                Framtida timmar
                                <span style="font-weight:400;margin-left:6px">(@_futureEvents.Count)</span>
                            </div>
                            @if (_futureEvents.Count == 0)
                            {
                                <div style="padding:12px 4px;color:#9E9E9E;font-size:13px">Inga kommande lektioner.</div>
                            }
                            @foreach (var evtF in (_showAllFuture ? _futureEvents : _futureEvents.Take(LessonPreviewCount)))
                            {
                                <LessonCard Evt="evtF" EduPlan="_profile.EduPlan" ExpandedLessonIds="_expandedLessonIds" OpenCommentIds="_openCommentIds" OnChanged="StateHasChanged" />
                            }
                            @if (_futureEvents.Count > LessonPreviewCount)
                            {
                                <div style="text-align:center;padding:4px 0 2px">
                                    <span style="font-size:12px;color:#1565C0;cursor:pointer;display:inline-flex;align-items:center;gap:3px"
                                          @onclick="() => { _showAllFuture = !_showAllFuture; }">
                                        <MudIcon Icon="@(_showAllFuture ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Style="font-size:15px" />
                                        @(_showAllFuture ? "Visa färre" : $"Visa fler ({_futureEvents.Count - LessonPreviewCount} till)")
                                    </span>
                                </div>
                            }
                        </div>

                        @* ── Behöver åtgärd ──────────────────────────────────────────── *@
                        @if (_attentionEvents.Count > 0)
                        {
                        <div style="margin-bottom:16px">
                            <div style="font-size:11px;font-weight:700;color:#E65100;text-transform:uppercase;letter-spacing:.06em;padding:6px 0 6px 2px;border-bottom:2px solid #FFE0B2;margin-bottom:6px;display:flex;align-items:center;gap:6px">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="font-size:14px;color:#E65100" />
                                Behöver åtgärd
                                <span style="font-weight:400;color:#BF360C;margin-left:2px">(@_attentionEvents.Count)</span>
                            </div>
                            <div style="font-size:11px;color:#8D6E63;margin-bottom:8px;padding:0 2px">
                                Tidigare lektioner som saknar moment eller har ett icke godkänt moment utan kommentar.
                            </div>
                            @foreach (var evtA in _attentionEvents)
                            {
                                <LessonCard Evt="evtA" EduPlan="_profile.EduPlan" IsAttention="true" ExpandedLessonIds="_expandedLessonIds" OpenCommentIds="_openCommentIds" OnChanged="StateHasChanged" />
                            }
                        </div>
                        }

                        @* ── Tidigare timmar ────────────────────────────────────────── *@
                        <div style="margin-bottom:16px">
                            <div style="font-size:11px;font-weight:700;color:#757575;text-transform:uppercase;letter-spacing:.06em;padding:6px 0 6px 2px;border-bottom:2px solid #E0E0E0;margin-bottom:6px">
                                Tidigare timmar
                                <span style="font-weight:400;margin-left:6px">(@_pastEvents.Count)</span>
                            </div>
                            @if (_pastEvents.Count == 0)
                            {
                                <div style="padding:12px 4px;color:#9E9E9E;font-size:13px">Inga tidigare lektioner.</div>
                            }
                            @foreach (var evtP in (_showAllPast ? _pastEvents : _pastEvents.Take(LessonPreviewCount)))
                            {
                                <LessonCard Evt="evtP" EduPlan="_profile.EduPlan" ExpandedLessonIds="_expandedLessonIds" OpenCommentIds="_openCommentIds" OnChanged="StateHasChanged" />
                            }
                            @if (_pastEvents.Count > LessonPreviewCount)
                            {
                                <div style="text-align:center;padding:4px 0 2px">
                                    <span style="font-size:12px;color:#1565C0;cursor:pointer;display:inline-flex;align-items:center;gap:3px"
                                          @onclick="() => { _showAllPast = !_showAllPast; }">
                                        <MudIcon Icon="@(_showAllPast ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Style="font-size:15px" />
                                        @(_showAllPast ? "Visa färre" : $"Visa fler ({_pastEvents.Count - LessonPreviewCount} till)")
                                    </span>
                                </div>
                            }
                        </div>

                    </MudTabPanel>

                </MudTabs>
        </div>
    </div>
}

@code {
    [Parameter] public string StudentName { get; set; } = "";

    private StudentProfile? _profile;
    private string _activeCategory       = "";
    private string _activeTheoryCategory = "";

    // ── Utbildning tab cached data ──────────────────────────────────────────
    private List<CalendarEvent> _futureEvents    = new();
    private List<CalendarEvent> _pastEvents      = new();
    private List<CalendarEvent> _attentionEvents = new();

    private void RebuildUtbildningData()
    {
        if (_profile == null) return;
        var allEvents = BookingService.GetEventsForStudent(_profile.Name).ToList();
        var now       = DateTime.Now;
        _futureEvents    = allEvents.Where(e => e.EndTime >= now).OrderBy(e => e.StartTime).ToList();
        _pastEvents      = allEvents.Where(e => e.EndTime  < now).OrderByDescending(e => e.StartTime).ToList();
        _attentionEvents = _pastEvents.Where(NeedsAttention).ToList();
    }

    // ── Elevinfo redigering ───────────────────────────────────────────────────
    private bool   _editMode        = false;
    private string _editNickName    = "";
    private string _editEmail       = "";
    private string _editPhone       = "";
    private string _editAddress     = "";
    private int    _editAge;
    private string _editGender      = "";
    private bool   _editSmsReminder = true;
    private List<ContactPerson> _editContacts = new();

    private void StartEdit()
    {
        _editNickName    = _profile!.NickName;
        _editEmail       = _profile.Email;
        _editPhone       = _profile.Phone;
        _editAddress     = _profile.Address;
        _editAge         = _profile.Age;
        _editGender      = _profile.Gender;
        _editSmsReminder = _profile.SmsReminder;
        _editContacts    = _profile.ContactPersons
                               .Select(c => new ContactPerson { Name=c.Name, Relation=c.Relation, Phone=c.Phone })
                               .ToList();
        _editMode = true;
    }

    private void SaveEdit()
    {
        _profile!.NickName    = _editNickName;
        _profile.Email        = _editEmail;
        _profile.Phone        = _editPhone;
        _profile.Address      = _editAddress;
        _profile.Age          = _editAge;
        _profile.Gender       = _editGender;
        _profile.SmsReminder  = _editSmsReminder;
        _profile.ContactPersons = _editContacts
                                      .Select(c => new ContactPerson { Name=c.Name, Relation=c.Relation, Phone=c.Phone })
                                      .ToList();
        _editMode = false;
    }

    private void CancelEdit() => _editMode = false;

    private void AddEditContact() =>
        _editContacts.Add(new ContactPerson { Name="", Relation="", Phone="" });

    // ── Kommentarer ─────────────────────────────────────────────────────────
    private record StudentNote(string Text, string Author, DateTime CreatedAt);

    private List<StudentNote> _studentNotes = new();
    private string _newNoteText = "";

    private void InitNotes()
    {
        // Mock-kommentarer
        _studentNotes = new()
        {
            new("Eleven har svårt med backning och fickparkering. Öva extra på detta.", "Karin Lind", new DateTime(2026, 3, 10, 14, 22, 0)),
            new("Kontaktad vårdnadshavare angående missad lektion 5/3.", "Admin", new DateTime(2026, 3, 6, 9, 5, 0)),
        };
    }

    private void AddStudentNote()
    {
        if (string.IsNullOrWhiteSpace(_newNoteText)) return;
        // I prototypen hårdkodar vi "Inloggad användare" – byts mot riktig auth senare
        _studentNotes.Insert(0, new StudentNote(_newNoteText.Trim(), "Karin Lind", DateTime.Now));
        _newNoteText = "";
    }

    // Utbildning tab state
    private HashSet<int>    _expandedLessonIds = new();
    private HashSet<string> _openCommentIds    = new();
    private static readonly System.Globalization.CultureInfo _sv = new("sv-SE");
    private bool _showAllFuture  = false;
    private bool _showAllPast    = false;
    private const int LessonPreviewCount = 3;

    /// <summary>True if the past event has no moments, or has a non-approved moment (Score &lt; 3) without a comment.</summary>
    private static bool NeedsAttention(CalendarEvent e) =>
        e.LinkedMoments.Count == 0 ||
        e.LinkedMoments.Any(m => m.Score < 3 && string.IsNullOrWhiteSpace(m.Comment));

    private List<TrainingStep> ActiveSteps =>
        _profile?.TrainingStepsByCategory.TryGetValue(_activeCategory, out var s) == true
            ? s : new();

    private List<TrainingStep> ActiveTheorySteps =>
        _profile?.TheoryStepsByCategory.TryGetValue(_activeTheoryCategory, out var s) == true
            ? s : new();

    protected override void OnParametersSet()
    {
        var decoded = Uri.UnescapeDataString(StudentName);
        _profile = BookingService.GetStudentProfile(decoded);
        var first = _profile.LicenseCategories.FirstOrDefault() ?? "";
        _activeCategory       = first;
        _activeTheoryCategory = first;
        RebuildUtbildningData();
        InitNotes();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    // ── Provstatus ────────────────────────────────────────────────────────
    private async Task BookNewExam(bool isTheory, string licenseCategory)
    {
        var parameters = new DialogParameters
        {
            [nameof(BookExamDialog.StudentName)]             = _profile!.Name,
            [nameof(BookExamDialog.Categories)]              = _profile.LicenseCategories,
            [nameof(BookExamDialog.PreselectedCategory)]     = licenseCategory,
            [nameof(BookExamDialog.PreselectedLessonTypeId)] = isTheory ? 10 : 7,
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<BookExamDialog>("Boka prov", parameters, options);
        var result  = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            StateHasChanged();
        }
    }

    private async Task OpenExamDialog(CalendarEvent ev, bool isTheory, string licenseCategory)
    {
        var parameters = new DialogParameters
        {
            [nameof(ExamStatusDialog.IsTheory)]        = isTheory,
            [nameof(ExamStatusDialog.LicenseCategory)] = licenseCategory,
            [nameof(ExamStatusDialog.ExamDate)]        = ev.StartTime,
            [nameof(ExamStatusDialog.Current)]         = ev.ExamResult ?? ExamResult.Pending,
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<ExamStatusDialog>("Uppdatera provstatus", parameters, options);
        var result  = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is ExamResult picked)
        {
            BookingService.UpdateExamResult(ev.Id, picked);
            StateHasChanged();
        }
    }

    private static (string Label, string Color, string Icon) ExamDisplay(CalendarEvent? ev) => ev?.ExamResult switch
    {
        ExamResult.Passed  => ("Godkänd",    "#2e7d32", Icons.Material.Filled.CheckCircle),
        ExamResult.Failed  => ("Ej godkänd", "#c62828", Icons.Material.Filled.Cancel),
        ExamResult.Pending => ("Väntar",     "#ef6c00", Icons.Material.Filled.Schedule),
        _                  => ("Ej bokat",   "#9e9e9e", Icons.Material.Filled.EventBusy),
    };

    private static string ScoreColor(int score) => score switch
    {
        0         => "#9e9e9e",
        1 or 2    => "#f44336",
        3         => "#ff9800",
        4         => "#8bc34a",
        5         => "#4caf50",
        _         => "#9e9e9e"
    };

    private static string ScoreLabel(int score) => score switch
    {
        0 => "Ej bedömd",
        1 => "1 – Ej godkänd",
        2 => "2 – Under förväntan",
        3 => "3 – Godtagbar",
        4 => "4 – Godkänd",
        5 => "5 – Mycket bra",
        _ => ""
    };

private static string StepBadgeStyle(TrainingStep s)
    {
        var bg = s.Score switch
        {
            0         => "#e0e0e0",
            1 or 2    => "#f44336",
            3         => "#ff9800",
            4 or 5    => "#4caf50",
            _         => "#e0e0e0"
        };
        return $"background-color:{bg};color:{(s.Score == 0 ? "#757575" : "white")};font-size:11px;width:20px;height:20px;min-width:20px";
    }

}
