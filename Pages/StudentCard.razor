                                                                <div style="flex:1;font-size:13px;font-weight:500">@moPc.Title</div>
                                                                <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:@MomentStatusColor(moPc.Score);color:white;white-space:nowrap;flex-shrink:0">@MomentStatusLabel(moPc.Score)</span>
                                                            </div>
