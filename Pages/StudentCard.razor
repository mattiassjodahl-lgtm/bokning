                                                        </div>
                                                    }
                                                </div>
                                            }
                                            @if (eduPlan != null)
                                            {
                                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(async () => await OpenMomentDialog(evP))">Lägg till utbildningsmoment</MudButton>
                                            }
                                            <div style="display:flex;gap:12px;align-items:center;margin-top:14px;padding-top:12px;border-top:1px solid #E8E8E8">
                                                <MudCheckBox T="bool" Value="@evP.Demonstrated" ValueChanged="@(v => { evP.Demonstrated = v; StateHasChanged(); })" Label="Demonstrerat" Dense="true" Color="Color.Primary" Size="Size.Small" />
                                                <MudCheckBox T="bool" Value="@evP.Instructed"    ValueChanged="@(v => { evP.Instructed = v; StateHasChanged(); })"    Label="Instruerat"   Dense="true" Color="Color.Primary" Size="Size.Small" />
                                                <MudCheckBox T="bool" Value="@evP.Independent"   ValueChanged="@(v => { evP.Independent = v; StateHasChanged(); })"   Label="Självständigt" Dense="true" Color="Color.Primary" Size="Size.Small" />
                                            </div>
                                            <div style="margin-top:8px">
                                                <MudTextField T="string" Value="@evP.LessonComment" ValueChanged="@(v => { evP.LessonComment = v; StateHasChanged(); })" Label="Kommentar för lektionen" Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            @if (pastEvents.Count > LessonPreviewCount)
                            {
                                <div style="text-align:center;padding:4px 0 2px">
                                    <span style="font-size:12px;color:#1565C0;cursor:pointer;display:inline-flex;align-items:center;gap:3px"
                                          @onclick="() => { _showAllPast = !_showAllPast; }">
                                        <MudIcon Icon="@(_showAllPast ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Style="font-size:15px" />
                                        @(_showAllPast ? "Visa färre" : $"Visa fler ({pastEvents.Count - LessonPreviewCount} till)")
                                    </span>
                                </div>
                            }
                        </div>

                    </MudTabPanel>

                </MudTabs>
        </div>
    </div>
}

