                        @* ── Behöver åtgärd ──────────────────────────────────────────── *@
                        @{
                            var attentionEvents = pastEvents.Where(NeedsAttention).ToList();
                        }
                        @if (attentionEvents.Count > 0)
                        {
                        <div style="margin-bottom:16px">
                            <div style="font-size:11px;font-weight:700;color:#E65100;text-transform:uppercase;letter-spacing:.06em;padding:6px 0 6px 2px;border-bottom:2px solid #FFE0B2;margin-bottom:6px;display:flex;align-items:center;gap:6px">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="font-size:14px;color:#E65100" />
                                Behöver åtgärd
                                <span style="font-weight:400;color:#BF360C;margin-left:2px">(@attentionEvents.Count)</span>
                            </div>
                            <div style="font-size:11px;color:#8D6E63;margin-bottom:8px;padding:0 2px">
                                Tidigare lektioner som saknar moment eller har ett icke godkänt moment utan kommentar.
                            </div>
                            @foreach (var evtA in attentionEvents)
                            {
                                var evA        = evtA;
                                var isExpA     = _expandedLessonIds.Contains(evA.Id);
                                var teacherA   = BookingService.GetTeacher(evA.TeacherId);
                                var ltA        = evA.LessonTypeId.HasValue ? BookingService.GetLessonType(evA.LessonTypeId.Value) : null;
                                var resourcesA = BookingService.GetResourcesById(evA.ResourceIds);
                                var mGroupsA   = eduPlan != null ? GroupMomentsBySection(evA, eduPlan) : EmptyMomentGroups();
                                var missingComment = evA.LinkedMoments.Any(m => m.Score < 3 && string.IsNullOrWhiteSpace(m.Comment));
                                var noMoments      = evA.LinkedMoments.Count == 0;
                                <div style="border:1px solid #FFCC80;border-left:4px solid #FF6D00;border-radius:8px;margin-bottom:8px;overflow:hidden">
                                    <div style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;background:#FFF8F0;cursor:pointer;user-select:none"
                                         @onclick="() => ToggleLessonExpand(evA.Id)">
                                        <div style="min-width:90px;flex-shrink:0">
                                            <div style="font-size:13px;font-weight:600;color:#212121">@evA.StartTime.ToString("d MMM", _sv)</div>
                                            <div style="font-size:11px;color:#9E9E9E">@evA.StartTime.ToString("HH:mm")–@evA.EndTime.ToString("HH:mm")</div>
                                        </div>
                                        <div style="flex:1;min-width:0">
                                            <div style="font-size:13px;font-weight:600;color:#212121;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@(ltA?.Name ?? "Lektion")</div>
                                            <div style="font-size:11px;color:#757575">
                                                @(teacherA?.Name ?? "")
                                                @if (resourcesA.Count > 0) { <span style="margin-left:4px">· @string.Join(", ", resourcesA.Select(r => r.Name))</span> }
                                            </div>
                                        </div>
                                        <div style="flex:1;min-width:0;display:flex;flex-wrap:wrap;gap:3px;align-items:flex-start">
                                            @if (noMoments)
                                            {
                                                <span style="font-size:11px;padding:1px 7px;border-radius:10px;background:#EF6C00;color:white;white-space:nowrap">Saknar moment</span>
                                            }
                                            @foreach (var mA in evA.LinkedMoments)
                                            {
                                                var needsCommentA = mA.Score < 3 && string.IsNullOrWhiteSpace(mA.Comment);
                                                <span style="font-size:10px;padding:1px 6px;border-radius:10px;background:@MomentStatusColor(mA.Score);color:white;white-space:nowrap;@(needsCommentA ? "outline:2px solid #FF6D00;outline-offset:1px" : "")">@mA.Title</span>
                                            }
                                        </div>
                                        <MudIcon Icon="@(isExpA ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Style="color:#9E9E9E;flex-shrink:0;margin-top:1px" />
                                    </div>
                                    @if (isExpA)
                                    {
                                        <div style="padding:12px 14px;border-top:1px solid #FFE0B2;background:white">
                                            @if (mGroupsA.Count == 0)
                                            {
                                                <div style="color:#EF6C00;font-size:13px;margin-bottom:12px;display:flex;align-items:center;gap:6px">
                                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Style="font-size:15px" />
                                                    Inga moment kopplade till denna lektion.
                                                </div>
                                            }
                                            @foreach (var grpA in mGroupsA)
                                            {
                                                <div style="margin-bottom:12px">
                                                    <div style="font-size:11px;font-weight:700;color:#1565C0;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px">
                                                        @if (!string.IsNullOrEmpty(grpA.Section.Mark)) { <span style="margin-right:4px">@grpA.Section.Mark</span> }
                                                        @grpA.Section.Title
                                                    </div>
                                                    @foreach (var moA in grpA.Moments)
                                                    {
                                                        var moAc = moA;
                                                        var ckA  = $"{evA.Id}_{moAc.GlobalId}";
                                                        var needsComA = moAc.Score < 3 && string.IsNullOrWhiteSpace(moAc.Comment);
                                                        <div style="border:1px solid @(needsComA ? "#FFCC80" : "#F0F0F0");border-left:@(needsComA ? "3px solid #FF6D00" : "1px solid #F0F0F0");border-radius:6px;padding:8px 10px;margin-bottom:6px;background:@(needsComA ? "#FFFAF5" : "#FAFAFA")">
                                                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
                                                                <div style="flex:1;font-size:13px;font-weight:500">@moAc.Title</div>
                                                                @if (needsComA)
                                                                {
                                                                    <span style="font-size:10px;padding:2px 7px;border-radius:10px;background:#EF6C00;color:white;white-space:nowrap;flex-shrink:0">Saknar kommentar</span>
                                                                }
                                                                <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:@MomentStatusColor(moAc.Score);color:white;white-space:nowrap;flex-shrink:0">@MomentStatusLabel(moAc.Score)</span>
                                                            </div>
                                                            <div class="sc-slider" style="margin:0 4px">
                                                                <MudSlider T="int" Value="@moAc.Score" ValueChanged="@(v => { moAc.Score = v; StateHasChanged(); })" Min="0" Max="5" Step="1" Color="@SliderColor(moAc.Score)" TickMarks="true" TickMarkLabels="@_sliderLabels" Immediate="true" Class="mb-3" />
                                                            </div>
                                                            <div style="display:flex;align-items:center;gap:6px;margin-top:-4px">
                                                                <span style="font-size:11px;color:#1565C0;cursor:pointer;display:flex;align-items:center;gap:3px" @onclick="() => ToggleComment(ckA)">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Comment" Style="font-size:13px" />
                                                                    @(IsCommentOpen(ckA) ? "Dölj kommentar" : (string.IsNullOrEmpty(moAc.Comment) ? "Lägg till kommentar" : "Visa kommentar"))
                                                                </span>
                                                                @if (!string.IsNullOrEmpty(moAc.Comment) && !IsCommentOpen(ckA)) { <span style="font-size:11px;color:#9E9E9E;font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px">@moAc.Comment</span> }
                                                            </div>
                                                            @if (IsCommentOpen(ckA)) { <div style="margin-top:8px"><MudTextField T="string" Value="@moAc.Comment" ValueChanged="@(v => { moAc.Comment = v; StateHasChanged(); })" Label="Kommentar" Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense" /></div> }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            @if (eduPlan != null)
                                            {
                                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(async () => await OpenMomentDialog(evA))">Lägg till utbildningsmoment</MudButton>
                                            }
                                            <div style="display:flex;gap:12px;align-items:center;margin-top:14px;padding-top:12px;border-top:1px solid #FFE0B2">
                                                <MudCheckBox T="bool" Value="@evA.Demonstrated" ValueChanged="@(v => { evA.Demonstrated = v; StateHasChanged(); })" Label="Demonstrerat" Dense="true" Color="Color.Primary" Size="Size.Small" />
                                                <MudCheckBox T="bool" Value="@evA.Instructed"    ValueChanged="@(v => { evA.Instructed = v; StateHasChanged(); })"    Label="Instruerat"   Dense="true" Color="Color.Primary" Size="Size.Small" />
                                                <MudCheckBox T="bool" Value="@evA.Independent"   ValueChanged="@(v => { evA.Independent = v; StateHasChanged(); })"   Label="Självständigt" Dense="true" Color="Color.Primary" Size="Size.Small" />
                                            </div>
                                            <div style="margin-top:8px">
                                                <MudTextField T="string" Value="@evA.LessonComment" ValueChanged="@(v => { evA.LessonComment = v; StateHasChanged(); })" Label="Kommentar för lektionen" Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        }

                        @* ── Tidigare timmar ────────────────────────────────────────── *@
                        <div style="margin-bottom:16px">
                            <div style="font-size:11px;font-weight:700;color:#757575;text-transform:uppercase;letter-spacing:.06em;padding:6px 0 6px 2px;border-bottom:2px solid #E0E0E0;margin-bottom:6px">
