@page "/"
@inject BookingService BookingService
@inject IDialogService DialogService
@using Heron.MudCalendar

<PageTitle>Kalendervy</PageTitle>

@* ═══════════════════════════════════════════════════════════════════════════ *@
@* App bar                                                                    *@
@* ═══════════════════════════════════════════════════════════════════════════ *@
<MudAppBar Color="Color.Primary" Fixed="true" Dense="true">
    <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Class="mr-2" />
    <MudText Typo="Typo.h6" Class="d-none d-sm-block">Kalendervy</MudText>
    <MudSpacer />

    @* Filter drawer toggle *@
    <MudIconButton Icon="@Icons.Material.Filled.FilterList" Color="Color.Inherit"
                   OnClick="ToggleFilterDrawer"
                   title="Filter" />

    @* New booking button *@
    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Inherit"
                   OnClick="OpenNewBookingDialog"
                   title="Ny bokning" />
</MudAppBar>

@* ═══════════════════════════════════════════════════════════════════════════ *@
@* Filter drawer                                                              *@
@* ═══════════════════════════════════════════════════════════════════════════ *@
<MudDrawer @bind-Open="_filterOpen" Anchor="Anchor.Right" Elevation="2"
           Width="280px" Variant="DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Filter</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="ToggleFilterDrawer" />
    </MudDrawerHeader>

    <MudDrawerContainer>
        <MudStack Spacing="3" Class="px-4 pt-2 pb-4">

            @* ── Personal – Grupp 1 & 2 ──────────────────────────────── *@
            <div>
                <MudText Typo="Typo.caption"
                         Style="font-weight:700;color:#555;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:8px">
                    Personal
                </MudText>

                @foreach (var grp in new[] { 1, 2 })
                {
                    var groupTeachers = BookingService.Teachers.Where(t => t.Group == grp).ToList();
                    var allSel        = groupTeachers.All(t  => _selectedTeacherIds.Contains(t.Id));
                    var anySel        = groupTeachers.Any(t  => _selectedTeacherIds.Contains(t.Id));
                    var g             = grp;

                    <div style="margin-bottom:10px">
                        <div style="display:flex;align-items:center;gap:4px;padding:3px 0;border-bottom:1px solid #e0e0e0;margin-bottom:4px;cursor:pointer"
                             @onclick="() => ToggleGroupAll(g)">
                            <MudCheckBox T="bool"
                                         Value="@allSel"
                                         Indeterminate="@(anySel && !allSel)"
                                         Color="Color.Primary"
                                         Dense="true"
                                         StopClickPropagation="true"
                                         ValueChanged="@(_ => ToggleGroupAll(g))" />
                            <span style="font-size:13px;font-weight:700;color:#333;user-select:none">Grupp @g</span>
                        </div>

                        <div style="margin-left:8px">
                            @foreach (var teacher in groupTeachers)
                            {
                                var tc    = teacher;
                                var isSel = _selectedTeacherIds.Contains(tc.Id);
                                <div style="display:flex;align-items:center;gap:6px;padding:2px 0;cursor:pointer"
                                     @onclick="() => ToggleTeacherInDrawer(tc.Id)">
                                    <MudCheckBox T="bool"
                                                 Value="@isSel"
                                                 Color="Color.Primary"
                                                 Dense="true"
                                                 StopClickPropagation="true"
                                                 ValueChanged="@(_ => ToggleTeacherInDrawer(tc.Id))" />
                                    <MudAvatar Style="@($"background-color:{tc.Color};color:white;width:20px;height:20px;font-size:9px;flex-shrink:0")"
                                               Size="Size.Small">@tc.Initials</MudAvatar>
                                    <span style="font-size:13px;user-select:none">@tc.Name</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            @* ── Resurser ─────────────────────────────────────────────── *@
            <MudSelect T="int"
                       Label="Resurser"
                       MultiSelection="true"
                       SelectedValues="_selectedResourceIds"
                       SelectedValuesChanged="@OnResourcesChanged"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomLeft"
                       AdornmentIcon="@Icons.Material.Filled.DirectionsCar"
                       Adornment="Adornment.Start"
                       Dense="true"
                       MultiSelectionTextFunc="@(s => PreviewText(s))">
                @foreach (var r in BookingService.Resources)
                {
                    <MudSelectItem T="int" Value="@r.Id" Text="@r.Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@r.Icon" Size="Size.Small" Style="font-size:16px" />
                            <span>@r.Name</span>
                            @if (!r.IsAvailable)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error">(ej tillgänglig)</MudText>
                            }
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>

            @* ── Lektionstyp (multi) ───────────────────────────────────── *@
            <MudSelect T="int"
                       Label="Lektionstyp"
                       MultiSelection="true"
                       SelectedValues="_selectedLessonTypeIds"
                       SelectedValuesChanged="OnLessonTypesChanged"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomLeft"
                       AdornmentIcon="@Icons.Material.Filled.School"
                       Adornment="Adornment.Start"
                       Dense="true"
                       MultiSelectionTextFunc="@(s => PreviewText(s))">
                @foreach (var lt in BookingService.LessonTypes)
                {
                    <MudSelectItem T="int" Value="@lt.Id" Text="@lt.Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@lt.Icon" Size="Size.Small" Style="font-size:16px" />
                            <span>@lt.Name</span>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>

            <MudDivider />

            @* ── Visa ─────────────────────────────────────────────────── *@
            <MudText Typo="Typo.subtitle2">Visa</MudText>
            <MudStack Spacing="0">
                <MudCheckBox T="bool" Value="@_filter.ShowAvailable" Label="Lediga tider"
                             ValueChanged="@((bool v) => { _filter.ShowAvailable = v; RefreshFilter(); })"
                             Color="Color.Success" Dense="true" />
                <MudCheckBox T="bool" Value="@_filter.ShowBooked" Label="Bokade lektioner"
                             ValueChanged="@((bool v) => { _filter.ShowBooked = v; RefreshFilter(); })"
                             Color="Color.Primary" Dense="true" />
            </MudStack>

            <MudDivider />

            @* ── Reset ────────────────────────────────────────────────── *@
            <MudButton Variant="Variant.Outlined" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="ResetFilter">
                Återställ filter
            </MudButton>

        </MudStack>
    </MudDrawerContainer>
</MudDrawer>

@* ═══════════════════════════════════════════════════════════════════════════ *@
@* Main content – MudCalendar                                                 *@
@* ═══════════════════════════════════════════════════════════════════════════ *@
<MudMainContent Class="cal-main-content">

    @* ── Quick teacher chips above calendar ──────────────────────────────── *@
    <MudPaper Elevation="0" Square="true" Class="d-flex align-center px-3 py-1 gap-2" Style="background:#f5f5f5;border-bottom:1px solid #e0e0e0">
        <MudSelect T="int"
                   Value="@_activeGroupFilter"
                   ValueChanged="@SetGroupFilter"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="min-width:130px;background:white;border-radius:4px"
                   Class="mr-2">
            <MudSelectItem T="int" Value="0">Alla grupper</MudSelectItem>
            <MudSelectItem T="int" Value="1">Grupp 1</MudSelectItem>
            <MudSelectItem T="int" Value="2">Grupp 2</MudSelectItem>
        </MudSelect>

        @foreach (var t in BookingService.Teachers.Where(t => _activeGroupFilter == 0 || t.Group == _activeGroupFilter))
        {
            <MudChip T="string"
                     Color="@(t.IsSelected ? Color.Primary : Color.Default)"
                     Variant="@(t.IsSelected ? Variant.Filled : Variant.Outlined)"
                     Size="Size.Small"
                     OnClick="@(() => ToggleTeacher(t))"
                     Style="@($"border-color:{t.Color}; {(t.IsSelected ? $"background-color:{t.Color}" : "")}")">
                @t.Initials
            </MudChip>
        }
    </MudPaper>

    @* ── MudCalendar replaces custom WeekView / MonthView / MobileViews ── *@
    <div style="flex:1;overflow:auto">
        <MudCalendar T="BookingCalendarItem"
                     Items="@_calendarItems"
                     ItemClicked="@OnCalendarItemClicked"
                     CellClicked="@OnCalendarCellClicked"
                     FirstDayOfWeek="DayOfWeek.Monday"
                     ShowWeek="true"
                     ShowWorkWeek="false"
                     ShowDay="true"
                     ShowMonth="true"
                     Style="height:100%"
                     ItemTemplate="@_itemTemplate" />
    </div>
</MudMainContent>

@code {
    // ── Item template ─────────────────────────────────────────────────────────
    private RenderFragment<BookingCalendarItem> _itemTemplate => bci =>
        builder =>
        {
            builder.OpenComponent<BookingCalendarItemView>(0);
            builder.AddAttribute(1, "Item", bci);
            builder.AddAttribute(2, "ShowTeacherAvatars", ActiveTeachers.Count > 1);
            builder.CloseComponent();
        };

    // ── State ─────────────────────────────────────────────────────────────────

    private bool _filterOpen;

    private CalendarFilter _filter = new()
    {
        ShowAvailable = true,
        ShowBooked    = true,
    };

    private int _activeGroupFilter = 0;

    private IReadOnlyCollection<int> _selectedTeacherIds    = new List<int>();
    private IReadOnlyCollection<int> _selectedResourceIds   = new List<int>();
    private IReadOnlyCollection<int> _selectedLessonTypeIds = new List<int>();

    // ── MudCalendar items (built from filtered events) ─────────────────────

    private IEnumerable<BookingCalendarItem> _calendarItems = Enumerable.Empty<BookingCalendarItem>();

    protected override void OnInitialized()
    {
        _selectedTeacherIds = BookingService.Teachers.Where(t => t.Group == 1).Select(t => t.Id).ToList();
        foreach (var t in BookingService.Teachers)
            t.IsSelected = _selectedTeacherIds.Contains(t.Id);
        RebuildCalendarItems();
    }

    private void RebuildCalendarItems()
    {
        _calendarItems = BookingService.Events
            .Where(e => MatchesFilter(e))
            .Select(e => new BookingCalendarItem(e))
            .ToList();
    }

    private bool MatchesFilter(CalendarEvent e)
    {
        // Show available / booked
        if (e.IsBooked && !_filter.ShowBooked) return false;
        if (!e.IsBooked && !_filter.ShowAvailable) return false;

        // Teacher filter
        if (_filter.SelectedTeacherIds.Count > 0 && !_filter.SelectedTeacherIds.Contains(e.TeacherId))
            return false;

        // Resource filter
        if (_filter.SelectedResourceIds.Count > 0 && !e.ResourceIds.Any(r => _filter.SelectedResourceIds.Contains(r)))
            return false;

        // Lesson type filter
        if (_filter.SelectedLessonTypeIds.Count > 0 && e.LessonTypeId.HasValue && !_filter.SelectedLessonTypeIds.Contains(e.LessonTypeId.Value))
            return false;

        return true;
    }

    private static string PreviewText(IReadOnlyList<string> selected) => selected.Count switch
    {
        0 => "",
        1 => selected[0],
        _ => $"{selected[0]} +{selected.Count - 1}",
    };

    private List<Teacher> ActiveTeachers =>
        BookingService.Teachers.Where(t => t.IsSelected).ToList();

    // ── MudCalendar event handlers ─────────────────────────────────────────

    private async Task OnCalendarItemClicked(BookingCalendarItem item)
    {
        var evt = item.Event;
        var parameters = new DialogParameters<BookingDialog>
        {
            { x => x.ExistingEvent, evt }
        };
        var dialog = await DialogService.ShowAsync<BookingDialog>("", parameters,
            new DialogOptions { CloseOnEscapeKey = true, CloseButton = true });
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            if (result.Data?.ToString() == "book_existing")
                await OpenBookingForSlot(evt.TeacherId, evt.StartTime, evt.LessonTypeId);
            RebuildCalendarItems();
            StateHasChanged();
        }
    }

    private async Task OnCalendarCellClicked(DateTime cellDate)
    {
        var startTime = cellDate.TimeOfDay == TimeSpan.Zero
            ? cellDate.AddHours(9)   // Clicked on a day cell (month view) → default 09:00
            : cellDate;              // Clicked on a time slot → use exact time
        await OpenBookingForSlot(ActiveTeachers.FirstOrDefault()?.Id ?? 0, startTime, null);
    }

    private async Task OpenBookingForSlot(int teacherId, DateTime startTime, int? lessonTypeId)
    {
        var parameters = new DialogParameters<BookingDialog>
        {
            { x => x.PreselectedTeacherId,    teacherId   },
            { x => x.PreselectedStart,        startTime   },
            { x => x.PreselectedLessonTypeId, lessonTypeId },
        };
        var dialog = await DialogService.ShowAsync<BookingDialog>("Boka lektion", parameters,
            new DialogOptions { CloseOnEscapeKey = true, CloseButton = true });
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            RebuildCalendarItems();
            StateHasChanged();
        }
    }

    // ── New booking (from app bar) ─────────────────────────────────────────

    private async Task OpenNewBookingDialog()
    {
        var parameters = new DialogParameters<BookingDialog>
        {
            { x => x.PreselectedStart,  DateTime.Today.AddHours(9) },
            { x => x.FindNextAvailable, true },
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, CloseButton = true };
        var dialog  = await DialogService.ShowAsync<BookingDialog>("Ny bokning", parameters, options);
        var result  = await dialog.Result;
        if (!result!.Canceled)
        {
            RebuildCalendarItems();
            StateHasChanged();
        }
    }

    // ── Teacher toggle (quick chips) ───────────────────────────────────────

    private void ToggleTeacher(Teacher t)
    {
        t.IsSelected = !t.IsSelected;
        _selectedTeacherIds = BookingService.Teachers.Where(x => x.IsSelected).Select(x => x.Id).ToList();
        RefreshFilter();
    }

    private void SetGroupFilter(int group)
    {
        _activeGroupFilter = group;
        StateHasChanged();
    }

    // ── Checkbox handlers (filter drawer) ──────────────────────────────────

    private void ToggleTeacherInDrawer(int id)
    {
        var sel = _selectedTeacherIds.ToHashSet();
        if (sel.Contains(id)) sel.Remove(id);
        else sel.Add(id);
        _selectedTeacherIds = sel;
        foreach (var t in BookingService.Teachers)
            t.IsSelected = sel.Contains(t.Id);
        RefreshFilter();
    }

    private void ToggleGroupAll(int group)
    {
        var groupIds    = BookingService.Teachers.Where(t => t.Group == group).Select(t => t.Id).ToHashSet();
        var sel         = _selectedTeacherIds.ToHashSet();
        bool allChosen  = groupIds.All(id => sel.Contains(id));
        if (allChosen)
            foreach (var id in groupIds) sel.Remove(id);
        else
            foreach (var id in groupIds) sel.Add(id);
        _selectedTeacherIds = sel;
        foreach (var t in BookingService.Teachers)
            t.IsSelected = sel.Contains(t.Id);
        RefreshFilter();
    }

    private void OnResourcesChanged(IReadOnlyCollection<int> selected)
    {
        _selectedResourceIds = selected;
        RefreshFilter();
    }

    private void OnLessonTypesChanged(IReadOnlyCollection<int> selected)
    {
        _selectedLessonTypeIds = selected;
        RefreshFilter();
    }

    // ── Filter ────────────────────────────────────────────────────────────────

    private void ToggleFilterDrawer() => _filterOpen = !_filterOpen;

    private void RefreshFilter()
    {
        _filter = new CalendarFilter
        {
            ShowAvailable          = _filter.ShowAvailable,
            ShowBooked             = _filter.ShowBooked,
            SelectedLessonTypeIds  = _selectedLessonTypeIds.ToList(),
            SelectedTeacherIds     = _selectedTeacherIds.ToList(),
            SelectedResourceIds    = _selectedResourceIds.ToList(),
        };
        RebuildCalendarItems();
        StateHasChanged();
    }

    private void ResetFilter()
    {
        _selectedTeacherIds    = BookingService.Teachers.Where(t => t.Group == 1).Select(t => t.Id).ToList();
        _selectedResourceIds   = new List<int>();
        _selectedLessonTypeIds = new List<int>();
        _activeGroupFilter     = 0;
        foreach (var t in BookingService.Teachers)
            t.IsSelected = t.Group == 1;
        _filter = new CalendarFilter { ShowAvailable = true, ShowBooked = true };
        RebuildCalendarItems();
        StateHasChanged();
    }
}
