@page "/"
@inject BookingService BookingService
@inject IDialogService DialogService

<PageTitle>Kalendervy</PageTitle>

@* ═══════════════════════════════════════════════════════════════════════════ *@
@* App bar                                                                    *@
@* ═══════════════════════════════════════════════════════════════════════════ *@
<MudAppBar Color="Color.Primary" Fixed="true" Dense="true">
    <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Class="mr-2" />
    <MudText Typo="Typo.h6" Class="d-none d-sm-block">Kalendervy</MudText>
    <MudSpacer />

    @* View switcher – high-contrast: active = white text on teal, inactive = white outline *@
    <MudButtonGroup Color="Color.Inherit" Variant="Variant.Outlined" Size="Size.Small" Class="mr-2">
        <MudButton OnClick='() => SetView("dag")'
                   Style="@(_currentView=="dag"
                       ? "background:white; color:#1565C0; font-weight:700; border-color:white"
                       : "color:white; border-color:rgba(255,255,255,0.6)")">
            Dag
        </MudButton>
        <MudButton OnClick='() => SetView("vecka")'
                   Style="@(_currentView=="vecka"
                       ? "background:white; color:#1565C0; font-weight:700; border-color:white"
                       : "color:white; border-color:rgba(255,255,255,0.6)")">
            Vecka
        </MudButton>
        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="false">
            <MudButton OnClick='() => SetView("månad")'
                       Style="@(_currentView=="månad"
                           ? "background:white; color:#1565C0; font-weight:700; border-color:white"
                           : "color:white; border-color:rgba(255,255,255,0.6)")">
                Månad
            </MudButton>
            <MudButton OnClick='() => SetView("lärare")'
                       Style="@(_currentView=="lärare"
                           ? "background:white; color:#1565C0; font-weight:700; border-color:white"
                           : "color:white; border-color:rgba(255,255,255,0.6)")">
                Lärare
            </MudButton>
        </MudHidden>
    </MudButtonGroup>

    @* Elevsökning – sökikon, inline-autocomplete eller aktiv elev-chip *@
    @if (_searchMode)
    {
        <div class="stu-search-wrap">
            <MudIcon Icon="@Icons.Material.Filled.Search" Style="color:rgba(255,255,255,.7); font-size:18px" />
            <MudAutocomplete @key="@_searchKey"
                             T="string"
                             Value="@_studentSearch"
                             SearchFunc="SearchStudents"
                             ValueChanged="OnStudentSelected"
                             Placeholder="Sök elev..."
                             ResetValueOnEmptyText="true"
                             CoerceText="false"
                             Immediate="true"
                             Style="flex:1; --mud-input-label-color:rgba(255,255,255,.7); --mud-input-text-color:white"
                             Variant="Variant.Text"
                             Dense="true"
                             AdornmentColor="Color.Inherit" />
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Color="Color.Inherit"
                           Size="Size.Small"
                           OnClick="ClearStudentSearch"
                           title="Stäng sökning" />
        </div>
    }
    else if (!string.IsNullOrEmpty(_selectedStudent))
    {
        <div class="stu-active-chip" @onclick="ClearStudentSearch" title="Rensa elevfilter">
            <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:16px" />
            @_selectedStudent
            <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:14px; opacity:.8" />
        </div>
    }
    else
    {
        <MudIconButton Icon="@Icons.Material.Filled.PersonSearch" Color="Color.Inherit"
                       OnClick="OpenStudentSearch"
                       title="Sök elev" />
    }

    @* Filter drawer toggle *@
    <MudIconButton Icon="@Icons.Material.Filled.FilterList" Color="Color.Inherit"
                   OnClick="ToggleFilterDrawer"
                   title="Filter" />

    @* Planning mode *@
    <MudIconButton Icon="@Icons.Material.Filled.EditCalendar" Color="Color.Inherit"
                   Href="/planning"
                   title="Planeringsläge" />

    @* Rapport-agent *@
    <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Inherit"
                   Href="/admin/rapporter"
                   title="Rapportagent (AI)" />

    @* New booking button *@
    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Inherit"
                   OnClick="OpenNewBookingDialog"
                   title="Ny bokning" />
</MudAppBar>

@* ═══════════════════════════════════════════════════════════════════════════ *@
@* Filter drawer                                                              *@
@* ═══════════════════════════════════════════════════════════════════════════ *@
<MudDrawer @bind-Open="_filterOpen" Anchor="Anchor.Right" Elevation="2"
           Width="280px" Variant="DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Filter</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="ToggleFilterDrawer" />
    </MudDrawerHeader>

    <MudDrawerContainer>
        <MudStack Spacing="3" Class="px-4 pt-2 pb-4">

            @* ── Personal – dynamiska grupper ──────────────────────────── *@
            <div>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="margin-bottom:8px">
                    <MudText Typo="Typo.caption"
                             Style="font-weight:700;color:#555;text-transform:uppercase;letter-spacing:.5px;flex:1">
                        Personal
                    </MudText>
                    <MudTooltip Text="Redigera grupper">
                        <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                       Size="Size.Small"
                                       Style="padding:2px"
                                       OnClick="OpenGroupEditor" />
                    </MudTooltip>
                </MudStack>

                @foreach (var tg in BookingService.TeacherGroups)
                {
                    var g             = tg;
                    var groupTeachers = BookingService.Teachers.Where(t => t.Group == g.Id).ToList();
                    var allSel        = groupTeachers.Count > 0 && groupTeachers.All(t => _selectedTeacherIds.Contains(t.Id));
                    var anySel        = groupTeachers.Any(t => _selectedTeacherIds.Contains(t.Id));
                    var expanded      = _groupExpanded.GetValueOrDefault(g.Id, false);

                    <div style="margin-bottom:6px">

                        @* Grupphuvud: chevron expanderar/fäller ihop, kryssruta väljer alla *@
                        <div style="display:flex;align-items:center;gap:4px;padding:3px 0;border-bottom:1px solid #e0e0e0;margin-bottom:4px">
                            <MudCheckBox T="bool"
                                         Value="@allSel"
                                         Indeterminate="@(anySel && !allSel)"
                                         Color="Color.Primary"
                                         Dense="true"
                                         StopClickPropagation="true"
                                         Disabled="@(groupTeachers.Count == 0)"
                                         ValueChanged="@(_ => ToggleGroupAll(g.Id))" />
                            <span style="font-size:13px;font-weight:700;color:#333;user-select:none;flex:1;cursor:pointer"
                                  @onclick="() => _groupExpanded[g.Id] = !expanded">
                                @g.Name
                            </span>
                            <MudIconButton Icon="@(expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                           Size="Size.Small"
                                           Style="padding:2px"
                                           OnClick="() => _groupExpanded[g.Id] = !expanded" />
                        </div>

                        @* Enskilda lärare – visas bara när gruppen är expanderad *@
                        @if (expanded)
                        {
                            <div style="margin-left:8px">
                                @if (groupTeachers.Count == 0)
                                {
                                    <div style="font-size:12px;color:#999;padding:4px 0">Inga lärare i denna grupp</div>
                                }
                                @foreach (var teacher in groupTeachers)
                                {
                                    var tc    = teacher;
                                    var isSel = _selectedTeacherIds.Contains(tc.Id);
                                    <div style="display:flex;align-items:center;gap:6px;padding:2px 0;cursor:pointer"
                                         @onclick="() => ToggleTeacherInDrawer(tc.Id)">
                                        <MudCheckBox T="bool"
                                                     Value="@isSel"
                                                     Color="Color.Primary"
                                                     Dense="true"
                                                     StopClickPropagation="true"
                                                     ValueChanged="@(_ => ToggleTeacherInDrawer(tc.Id))" />
                                        <MudAvatar Style="@($"background-color:{tc.Color};color:white;width:20px;height:20px;font-size:9px;flex-shrink:0")"
                                                   Size="Size.Small">@tc.Initials</MudAvatar>
                                        <span style="font-size:13px;user-select:none">@tc.Name</span>
                                    </div>
                                }
                            </div>
                        }

                    </div>
                }
            </div>

            @* ── Resurser – grupperade per ResourceType ───────────────── *@
            <div>
                <MudText Typo="Typo.caption"
                         Style="font-weight:700;color:#555;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:8px">
                    Resurser
                </MudText>

                @foreach (var rg in ResourceGroups)
                {
                    var grp            = rg;
                    var groupResources = BookingService.Resources.Where(r => r.Type == grp.Type).ToList();
                    if (groupResources.Count == 0) continue;

                    var allSel   = groupResources.All(r => _selectedResourceIds.Contains(r.Id));
                    var anySel   = groupResources.Any(r => _selectedResourceIds.Contains(r.Id));
                    var expanded = _resourceGroupExpanded.GetValueOrDefault(grp.Type, false);

                    <div style="margin-bottom:6px">

                        @* Grupphuvud *@
                        <div style="display:flex;align-items:center;gap:4px;padding:3px 0;border-bottom:1px solid #e0e0e0;margin-bottom:4px">
                            <MudCheckBox T="bool"
                                         Value="@allSel"
                                         Indeterminate="@(anySel && !allSel)"
                                         Color="Color.Primary"
                                         Dense="true"
                                         StopClickPropagation="true"
                                         ValueChanged="@(_ => ToggleResourceGroupAll(grp.Type))" />
                            <span style="font-size:13px;font-weight:700;color:#333;user-select:none;flex:1;cursor:pointer"
                                  @onclick="() => _resourceGroupExpanded[grp.Type] = !expanded">
                                @grp.Label
                            </span>
                            <MudIconButton Icon="@(expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                           Size="Size.Small"
                                           Style="padding:2px"
                                           OnClick="() => _resourceGroupExpanded[grp.Type] = !expanded" />
                        </div>

                        @* Enskilda resurser *@
                        @if (expanded)
                        {
                            <div style="margin-left:8px">
                                @foreach (var resource in groupResources)
                                {
                                    var r     = resource;
                                    var isSel = _selectedResourceIds.Contains(r.Id);
                                    <div style="display:flex;align-items:center;gap:6px;padding:2px 0;cursor:pointer"
                                         @onclick="() => ToggleResourceInDrawer(r.Id)">
                                        <MudCheckBox T="bool"
                                                     Value="@isSel"
                                                     Color="Color.Primary"
                                                     Dense="true"
                                                     StopClickPropagation="true"
                                                     ValueChanged="@(_ => ToggleResourceInDrawer(r.Id))" />
                                        <MudIcon Icon="@r.Icon" Style="font-size:16px;color:#546e7a;flex-shrink:0" />
                                        <span style="font-size:13px;user-select:none">@r.Name</span>
                                        @if (!r.IsAvailable)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Error" Style="margin-left:4px">(ej tillgänglig)</MudText>
                                        }
                                    </div>
                                }
                            </div>
                        }

                    </div>
                }
            </div>

            @* ── Lektionstyp (multi) ───────────────────────────────────── *@
            <MudSelect T="int"
                       Label="Lektionstyp"
                       MultiSelection="true"
                       SelectedValues="_selectedLessonTypeIds"
                       SelectedValuesChanged="OnLessonTypesChanged"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomLeft"
                       AdornmentIcon="@Icons.Material.Filled.School"
                       Adornment="Adornment.Start"
                       Dense="true"
                       MultiSelectionTextFunc="@(s => PreviewText(s))">
                @foreach (var lt in BookingService.LessonTypes)
                {
                    <MudSelectItem T="int" Value="@lt.Id" Text="@lt.Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@lt.Icon" Size="Size.Small" Style="font-size:16px" />
                            <span>@lt.Name</span>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>

            <MudDivider />

            @* ── Visa ─────────────────────────────────────────────────── *@
            <MudText Typo="Typo.subtitle2">Visa</MudText>
            <MudStack Spacing="0">
                <MudCheckBox T="bool" Value="@_filter.ShowAvailable" Label="Lediga tider"
                             ValueChanged="@((bool v) => { _filter.ShowAvailable = v; RefreshFilter(); })"
                             Color="Color.Success" Dense="true" />
                <MudCheckBox T="bool" Value="@_filter.ShowBooked" Label="Bokade lektioner"
                             ValueChanged="@((bool v) => { _filter.ShowBooked = v; RefreshFilter(); })"
                             Color="Color.Primary" Dense="true" />
                <MudCheckBox T="bool" Value="@_filter.ShowOnlyFullyBooked" Label="Endast fullbokade"
                             ValueChanged="@((bool v) => { _filter.ShowOnlyFullyBooked = v; RefreshFilter(); })"
                             Color="Color.Error" Dense="true" />
            </MudStack>

            <MudDivider />

            @* ── Helgdagar ────────────────────────────────────────────── *@
            <MudButton Variant="@(_filter.HideWeekends ? Variant.Filled : Variant.Outlined)"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.DateRange"
                       OnClick="ToggleHideWeekends">
                @(_filter.HideWeekends ? "Visar mån–fre" : "Dölj lördagar och söndagar")
            </MudButton>

            @* ── Lärarinitialerna ──────────────────────────────────────── *@
            <MudButton Variant="@(_filter.HideTeacherAvatars ? Variant.Filled : Variant.Outlined)"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Person"
                       OnClick="ToggleHideTeacherAvatars">
                @(_filter.HideTeacherAvatars ? "Visar lärarinitialer" : "Dölj lärarinitialer")
            </MudButton>

            <MudDivider />

            @* ── Reset ────────────────────────────────────────────────── *@
            <MudButton Variant="Variant.Outlined" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="ResetFilter">
                Återställ filter
            </MudButton>

        </MudStack>
    </MudDrawerContainer>
</MudDrawer>

@* ═══════════════════════════════════════════════════════════════════════════ *@
@* Main content                                                               *@
@* ═══════════════════════════════════════════════════════════════════════════ *@
<MudMainContent Class="cal-main-content">

    @* ── Navigation toolbar ─────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Square="true" Class="cal-nav-bar d-flex align-center px-3 py-1 gap-2">
        <MudButton Size="Size.Small" OnClick="PrevPeriod"
                   StartIcon="@Icons.Material.Filled.ChevronLeft">@PrevLabel</MudButton>
        <MudButton Size="Size.Small" OnClick="GoToToday" Variant="Variant.Outlined">Idag</MudButton>
        <MudButton Size="Size.Small" OnClick="NextPeriod"
                   EndIcon="@Icons.Material.Filled.ChevronRight">@NextLabel</MudButton>

        @* Period title – clickable to open date picker *@
        <div style="flex:1; position:relative" class="ml-2">
            <MudButton OnClick="ToggleDatePicker"
                       EndIcon="@Icons.Material.Filled.CalendarMonth"
                       Size="Size.Small"
                       Style="text-transform:none; font-size:14px; font-weight:500; letter-spacing:0">
                @PeriodTitle
            </MudButton>

            @if (_datePickerOpen)
            {
                @* Backdrop – closes picker when clicking outside *@
                <div style="position:fixed; inset:0; z-index:998" @onclick="CloseDatePicker"></div>

                @* Calendar panel *@
                <MudPaper Elevation="8" Style="position:absolute; top:calc(100% + 4px); left:0; z-index:999; min-width:296px; overflow:hidden; border-radius:8px">
                    <MudDatePicker PickerVariant="PickerVariant.Static"
                                   Date="@_currentDate"
                                   DateChanged="@OnPickerDateSelected"
                                   ShowWeekNumbers="true"
                                   FirstDayOfWeek="DayOfWeek.Monday"
                                   Color="Color.Primary"
                                   Culture="@_sv" />
                </MudPaper>
            }
        </div>

        @* Quick teacher chips (visible on desktop, hideable via filter) *@
        @if (!_filter.HideTeacherAvatars)
        {
            <div class="d-none d-md-flex align-center gap-1">
                @* Group filter dropdown *@
                <MudSelect T="int"
                           Value="@_activeGroupFilter"
                           ValueChanged="@SetGroupFilter"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Style="min-width:130px;background:white;border-radius:4px"
                           Class="mr-2">
                    <MudSelectItem T="int" Value="0">Alla grupper</MudSelectItem>
                    @foreach (var g in BookingService.TeacherGroups)
                    {
                        <MudSelectItem T="int" Value="@g.Id">@g.Name</MudSelectItem>
                    }
                </MudSelect>

                @* Teacher chips, filtered by group *@
                @foreach (var t in BookingService.Teachers.Where(t => _activeGroupFilter == 0 || t.Group == _activeGroupFilter))
                {
                    <MudChip T="string"
                             Color="@(t.IsSelected ? Color.Primary : Color.Default)"
                             Variant="@(t.IsSelected ? Variant.Filled : Variant.Outlined)"
                             Size="Size.Small"
                             OnClick="@(() => ToggleTeacher(t))"
                             Style="@($"border-color:{t.Color}; {(t.IsSelected ? $"background-color:{t.Color}" : "")}")">
                        @t.Initials
                    </MudChip>
                }
            </div>
        }
    </MudPaper>

    @* ── Calendar views ─────────────────────────────────────────────────── *@
    <div class="cal-scroll-area">

        @* Desktop: grid-based week/day/month/teacher view (hidden on mobile) *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="false">
            @if (_currentView == "dag")
            {
                <WeekView DisplayDays="@(new List<DateTime>{ _currentDate })"
                          Filter="@_filter"
                          ActiveTeachers="@ActiveTeachers"
                          SelectedStudent="@_selectedStudent"
                          OnBookingChanged="@OnBookingChanged" />
            }
            else if (_currentView == "vecka")
            {
                <WeekView DisplayDays="@CurrentWeekDays"
                          Filter="@_filter"
                          ActiveTeachers="@ActiveTeachers"
                          SelectedStudent="@_selectedStudent"
                          OnBookingChanged="@OnBookingChanged" />
            }
            else if (_currentView == "lärare")
            {
                <TeacherWeekView DisplayDays="@CurrentWeekDays"
                                 Filter="@_filter"
                                 ActiveTeachers="@ActiveTeachers"
                                 SelectedStudent="@_selectedStudent"
                                 OnBookingChanged="@OnBookingChanged" />
            }
            else
            {
                <MonthView CurrentMonth="@_currentDate"
                           Filter="@_filter"
                           SelectedStudent="@_selectedStudent"
                           OnBookingChanged="@OnBookingChanged" />
            }
        </MudHidden>

        @* Mobile views (shown only on small screens) *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
            @if (_currentView == "vecka")
            {
                <MobileWeekView DisplayDays="@CurrentWeekDays"
                                Filter="@_filter"
                                ActiveTeachers="@ActiveTeachers"
                                OnBookingChanged="@OnBookingChanged" />
            }
            else
            {
                <MobileAgendaView WeekDays="@CurrentWeekDays"
                                  CurrentDate="@_currentDate"
                                  Filter="@_filter"
                                  OnBookingChanged="@OnBookingChanged" />
            }
        </MudHidden>
    </div>
</MudMainContent>

@code {
    // ── State ─────────────────────────────────────────────────────────────────

    private string _currentView = "vecka";
    private DateTime _currentDate = DateTime.Today;
    private bool _filterOpen;
    private bool _datePickerOpen;

    // ── Grupper ihopfällda per default (nyckel = TeacherGroup.Id) ─────────────
    private Dictionary<int, bool> _groupExpanded = new();

    // ── Elevsökning ───────────────────────────────────────────────────────────
    private bool   _searchMode      = false;
    private string _studentSearch   = "";
    private string _selectedStudent = "";
    private int    _searchKey       = 0;  // ökas vid varje öppning för att tvinga remount av MudAutocomplete

    private void OpenStudentSearch()
    {
        _searchMode    = true;
        _studentSearch = "";
        _searchKey++;
    }

    private void ClearStudentSearch()
    {
        _searchMode      = false;
        _studentSearch   = "";
        _selectedStudent = "";
        StateHasChanged();
    }

    private void OnStudentSelected(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return;
        _selectedStudent = name;
        _studentSearch   = "";
        _searchMode      = false;
        StateHasChanged();
    }

    private Task<IEnumerable<string>> SearchStudents(string search, CancellationToken _)
        => Task.FromResult(BookingService.SearchStudents(search));

    private CalendarFilter _filter = new()
    {
        ShowAvailable = true,
        ShowBooked    = true,
    };

    // ── Group filter for quick-chips in nav bar (0 = Alla, annars TeacherGroup.Id)
    private int _activeGroupFilter = 0;

    // Multi-select dropdown state — initialised in OnInitialized
    private IEnumerable<int> _selectedTeacherIds    = new List<int>();
    private IEnumerable<int> _selectedResourceIds   = new List<int>();
    private IEnumerable<int> _selectedLessonTypeIds = new List<int>();

    protected override void OnInitialized()
    {
        // Default: första gruppens lärare valda (matchar tidigare "Grupp 1"-beteende).
        var firstGroupId    = BookingService.TeacherGroups.FirstOrDefault()?.Id ?? 0;
        _selectedTeacherIds = BookingService.Teachers
            .Where(t => t.Group == firstGroupId)
            .Select(t => t.Id)
            .ToList();
        foreach (var t in BookingService.Teachers)
            t.IsSelected = _selectedTeacherIds.Contains(t.Id);
    }

    // Shows "Anna Lindgren" for 1 selected, "Anna Lindgren +2" for 3 selected, etc.
    private static string PreviewText(List<string> selected) => selected.Count switch
    {
        0 => "",
        1 => selected[0],
        _ => $"{selected[0]} +{selected.Count - 1}",
    };

    private List<Teacher> ActiveTeachers =>
        BookingService.Teachers.Where(t => t.IsSelected).ToList();

    // Resurs-grupper i filter-drawer (en rad per ResourceType som har resurser).
    private static readonly (ResourceType Type, string Label)[] ResourceGroups = new[]
    {
        (ResourceType.Car,       "Bilar"),
        (ResourceType.Classroom, "Klassrum"),
        (ResourceType.Simulator, "Simulatorer"),
        (ResourceType.Other,     "Övrigt"),
    };

    private Dictionary<ResourceType, bool> _resourceGroupExpanded = new()
    {
        { ResourceType.Car,       false },
        { ResourceType.Classroom, false },
        { ResourceType.Simulator, false },
        { ResourceType.Other,     false },
    };

    // ── Period helpers ────────────────────────────────────────────────────────

    private List<DateTime> CurrentWeekDays
    {
        get
        {
            var monday = _currentDate.AddDays(-(int)_currentDate.DayOfWeek + (int)DayOfWeek.Monday);
            if (_currentDate.DayOfWeek == DayOfWeek.Sunday) monday = monday.AddDays(-7);
            var days = Enumerable.Range(0, 7).Select(i => monday.AddDays(i));
            if (_filter.HideWeekends)
                days = days.Where(d => d.DayOfWeek != DayOfWeek.Saturday && d.DayOfWeek != DayOfWeek.Sunday);
            return days.ToList();
        }
    }

    private string PrevLabel => _currentView switch
    {
        "dag"    => "Igår",
        "vecka"  => "Förra veckan",
        "lärare" => "Förra veckan",
        _        => "Förra månaden",
    };

    private string NextLabel => _currentView switch
    {
        "dag"    => "Imorgon",
        "vecka"  => "Nästa vecka",
        "lärare" => "Nästa vecka",
        _        => "Nästa månad",
    };

    private string PeriodTitle => _currentView switch
    {
        "dag"    => _currentDate.ToString("dddd d MMMM yyyy", _sv),
        "vecka"  => $"Vecka {GetIso8601WeekOfYear(_currentDate)} · {CurrentWeekDays[0]:d MMM} – {CurrentWeekDays[^1]:d MMM yyyy}",
        "lärare" => $"Vecka {GetIso8601WeekOfYear(_currentDate)} · {CurrentWeekDays[0]:d MMM} – {CurrentWeekDays[^1]:d MMM yyyy}",
        "månad"  => _currentDate.ToString("MMMM yyyy", _sv),
        _        => ""
    };

    private System.Globalization.CultureInfo _sv = new("sv-SE");

    // ── Navigation ────────────────────────────────────────────────────────────

    private void SetView(string view)
    {
        _currentView = view;
        StateHasChanged();
    }

    private void PrevPeriod() =>
        _currentDate = _currentView switch
        {
            "dag"              => _currentDate.AddDays(-1),
            "vecka" or "lärare" => _currentDate.AddDays(-7),
            _                  => _currentDate.AddMonths(-1),
        };

    private void NextPeriod() =>
        _currentDate = _currentView switch
        {
            "dag"              => _currentDate.AddDays(1),
            "vecka" or "lärare" => _currentDate.AddDays(7),
            _                  => _currentDate.AddMonths(1),
        };

    private void GoToToday() => _currentDate = DateTime.Today;

    private void ToggleDatePicker() => _datePickerOpen = !_datePickerOpen;
    private void CloseDatePicker()  => _datePickerOpen = false;

    private void OnPickerDateSelected(DateTime? date)
    {
        if (date.HasValue)
        {
            _currentDate    = date.Value;
            _datePickerOpen = false;
        }
    }

    // ── Teacher toggle (quick chips in nav bar) ───────────────────────────────

    private void ToggleTeacher(Teacher t)
    {
        t.IsSelected = !t.IsSelected;
        _selectedTeacherIds = BookingService.Teachers.Where(x => x.IsSelected).Select(x => x.Id).ToList();
        RefreshFilter();
    }

    // ── Group filter toggle (nav bar dropdown) ────────────────────────────────

    private void SetGroupFilter(int group)
    {
        _activeGroupFilter = group;
        StateHasChanged();
    }

    // ── Checkbox handlers (filter drawer) ────────────────────────────────────

    private void ToggleTeacherInDrawer(int id)
    {
        var sel = _selectedTeacherIds.ToHashSet();
        if (sel.Contains(id)) sel.Remove(id);
        else sel.Add(id);
        _selectedTeacherIds = sel;
        foreach (var t in BookingService.Teachers)
            t.IsSelected = sel.Contains(t.Id);
        RefreshFilter();
    }

    private void ToggleGroupAll(int group)
    {
        var groupIds    = BookingService.Teachers.Where(t => t.Group == group).Select(t => t.Id).ToHashSet();
        var sel         = _selectedTeacherIds.ToHashSet();
        bool allChosen  = groupIds.All(id => sel.Contains(id));
        if (allChosen)
            foreach (var id in groupIds) sel.Remove(id);
        else
            foreach (var id in groupIds) sel.Add(id);
        _selectedTeacherIds = sel;
        foreach (var t in BookingService.Teachers)
            t.IsSelected = sel.Contains(t.Id);
        RefreshFilter();
    }

    private void OnTeachersChanged(IEnumerable<int> selected)
    {
        _selectedTeacherIds = selected.ToList();
        foreach (var t in BookingService.Teachers)
            t.IsSelected = _selectedTeacherIds.Contains(t.Id);
        RefreshFilter();
    }

    private void OnResourcesChanged(IEnumerable<int> selected)
    {
        _selectedResourceIds = selected.ToList();
        RefreshFilter();
    }

    private void ToggleResourceInDrawer(int id)
    {
        var sel = _selectedResourceIds.ToHashSet();
        if (sel.Contains(id)) sel.Remove(id);
        else sel.Add(id);
        _selectedResourceIds = sel;
        RefreshFilter();
    }

    private void ToggleResourceGroupAll(ResourceType type)
    {
        var groupIds = BookingService.Resources.Where(r => r.Type == type).Select(r => r.Id).ToHashSet();
        var sel      = _selectedResourceIds.ToHashSet();
        bool allChosen = groupIds.Count > 0 && groupIds.All(id => sel.Contains(id));
        if (allChosen)
            foreach (var id in groupIds) sel.Remove(id);
        else
            foreach (var id in groupIds) sel.Add(id);
        _selectedResourceIds = sel;
        RefreshFilter();
    }

    private void OnLessonTypesChanged(IEnumerable<int> selected)
    {
        _selectedLessonTypeIds = selected.ToList();
        RefreshFilter();
    }

    // ── Filter ────────────────────────────────────────────────────────────────

    private void ToggleFilterDrawer() => _filterOpen = !_filterOpen;

    private void RefreshFilter()
    {
        _filter = new CalendarFilter
        {
            ShowAvailable          = _filter.ShowAvailable,
            ShowBooked             = _filter.ShowBooked,
            ShowOnlyFullyBooked    = _filter.ShowOnlyFullyBooked,
            HideWeekends           = _filter.HideWeekends,
            HideTeacherAvatars     = _filter.HideTeacherAvatars,
            SelectedLessonTypeIds  = _selectedLessonTypeIds.ToList(),
            SelectedTeacherIds     = _selectedTeacherIds.ToList(),
            SelectedResourceIds    = _selectedResourceIds.ToList(),
        };
        StateHasChanged();
    }

    private void ToggleHideWeekends()
    {
        _filter.HideWeekends = !_filter.HideWeekends;
        RefreshFilter();
    }

    private void ToggleHideTeacherAvatars()
    {
        _filter.HideTeacherAvatars = !_filter.HideTeacherAvatars;
        RefreshFilter();
    }

    private void ResetFilter()
    {
        // Återställer till första gruppens lärare valda – matchar tidigare "Grupp 1"-beteende.
        var firstGroupId       = BookingService.TeacherGroups.FirstOrDefault()?.Id ?? 0;
        _selectedTeacherIds    = BookingService.Teachers.Where(t => t.Group == firstGroupId).Select(t => t.Id).ToList();
        _selectedResourceIds   = new List<int>();
        _selectedLessonTypeIds = new List<int>();
        _activeGroupFilter     = 0;
        foreach (var t in BookingService.Teachers)
            t.IsSelected = t.Group == firstGroupId;
        _filter = new CalendarFilter { ShowAvailable = true, ShowBooked = true, HideWeekends = false, HideTeacherAvatars = false };
        StateHasChanged();
    }

    // ── Group editor dialog ───────────────────────────────────────────────────

    private async Task OpenGroupEditor()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<GroupEditDialog>("", options);
        await dialog.Result;

        // Synka urval efter eventuella ändringar: ta bort ids som inte längre finns
        // eller hör till en raderad grupp, och uppdatera IsSelected.
        var validTeacherIds = BookingService.Teachers.Select(t => t.Id).ToHashSet();
        _selectedTeacherIds = _selectedTeacherIds.Where(id => validTeacherIds.Contains(id)).ToList();
        foreach (var t in BookingService.Teachers)
            t.IsSelected = _selectedTeacherIds.Contains(t.Id);

        // Nollställ nav-bar-dropdown om aktivt filter pekar på en raderad grupp.
        if (_activeGroupFilter != 0 && !BookingService.TeacherGroups.Any(g => g.Id == _activeGroupFilter))
            _activeGroupFilter = 0;

        RefreshFilter();
    }

    // ── Booking dialog ────────────────────────────────────────────────────────

    private async Task OpenNewBookingDialog()
    {
        var parameters = new DialogParameters<BookingDialog>
        {
            { x => x.PreselectedStart,  _currentDate.Date.AddHours(9) },
            { x => x.FindNextAvailable, true },
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, CloseButton = true };
        var dialog  = await DialogService.ShowAsync<BookingDialog>("Ny bokning", parameters, options);
        var result  = await dialog.Result;
        if (!result!.Canceled) StateHasChanged();
    }

    private Task OnBookingChanged()
    {
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ── ISO week number ───────────────────────────────────────────────────────

    private static int GetIso8601WeekOfYear(DateTime date)
    {
        var day = (int)System.Globalization.CultureInfo.InvariantCulture.Calendar
            .GetDayOfWeek(date);
        if (day is >= 1 and <= 3) date = date.AddDays(3);
        return System.Globalization.CultureInfo.InvariantCulture.Calendar
            .GetWeekOfYear(date, System.Globalization.CalendarWeekRule.FirstFourDayWeek,
                DayOfWeek.Monday);
    }
}
