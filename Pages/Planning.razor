    // ── Lesson type picking ───────────────────────────────────────────────────

    private void TogglePick(int ltId)
    {
        _pickedLessonTypeId = _pickedLessonTypeId == ltId ? null : ltId;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            _pickedLessonTypeId = null;
            _isDragging = false;
        }
    }

    // ── Drag and drop ─────────────────────────────────────────────────────────

    private void OnDragStart(int ltId)
    {
        _pickedLessonTypeId = ltId;
        _draggingBlock      = null;
        _isDragging         = true;
    }

    private void OnBlockDragStart(ScheduleTimeBlock block)
    {
        _draggingBlock      = block;
        _pickedLessonTypeId = null;
        _isDragging         = true;
    }

    private void OnDragEnd()
    {
        _isDragging    = false;
        _draggingBlock = null;
    }

    private void OnSlotDrop(int dayIndex, TimeOnly slotTime)
    {
        if (_draggingBlock != null)
        {
            MoveBlock(_draggingBlock, dayIndex, slotTime);
            _draggingBlock = null;
            _isDragging    = false;
            return;
        }
        OnSlotClick(dayIndex, slotTime);
        _isDragging = false;
    }

    private void MoveBlock(ScheduleTimeBlock block, int targetDay, TimeOnly newTime)
    {
        if (_template == null) return;
        var snapped = SnapTo5(newTime);
        var lt      = GetLessonType(block.LessonTypeId);
        var endTime = snapped.AddMinutes(lt?.DefaultDurationMinutes ?? 60);
        if (endTime > new TimeOnly(EndHour, 0)) return;

        // Konfliktkontroll, exkludera blocket självt
        bool conflict = _template.TimeBlocks
            .Where(b => b.WeekNumber == _activeWeek && b.DayOfWeek == targetDay && b.Id != block.Id)
            .Any(b =>
            {
                var bLt  = GetLessonType(b.LessonTypeId);
                var bEnd = b.StartTime.AddMinutes(bLt?.DefaultDurationMinutes ?? 60);
                return snapped < bEnd && endTime > b.StartTime;
            });
        if (conflict) return;

        block.DayOfWeek = targetDay;
        block.StartTime = snapped;
        ValidateConflicts();
    }

    // ── Slot / block interaction ──────────────────────────────────────────────

    private void OnDayColClick(int dayIndex, TimeOnly? time) { /* handled by slot clicks */ }

    private void OnSlotClick(int dayIndex, TimeOnly slotTime)
    {
        if (_template == null || !_pickedLessonTypeId.HasValue) return;
        if (IsSlotCovered(dayIndex, slotTime)) return;

        var lt = GetLessonType(_pickedLessonTypeId.Value);
        if (lt == null) return;

        // Snap to nearest 15 min
        var snapped = SnapTo5(slotTime);

        // Check if block would extend past end of grid
        var endTime = snapped.AddMinutes(lt.DefaultDurationMinutes);
        if (endTime > new TimeOnly(EndHour, 0)) return;

        var block = new ScheduleTimeBlock
        {
            Id           = BookingService.GetNextBlockId(),
            WeekNumber   = _activeWeek,
            DayOfWeek    = dayIndex,
            StartTime    = snapped,
            LessonTypeId = _pickedLessonTypeId.Value
        };

        _template.TimeBlocks.Add(block);
        ValidateConflicts();
    }

    private void RemoveBlock(int blockId)
    {
        _template?.TimeBlocks.RemoveAll(b => b.Id == blockId);
        ValidateConflicts();
    }

    // ── Conflict detection ────────────────────────────────────────────────────

    private void ValidateConflicts()
    {
        _conflicts.Clear();
        if (_template == null) return;

        var blocks = _template.TimeBlocks.Where(b => b.WeekNumber == _activeWeek).ToList();
        for (int i = 0; i < blocks.Count; i++)
        {
            for (int j = i + 1; j < blocks.Count; j++)
            {
                var a = blocks[i];
                var b = blocks[j];
                if (a.DayOfWeek != b.DayOfWeek) continue;

                var aLt  = GetLessonType(a.LessonTypeId);
                var bLt  = GetLessonType(b.LessonTypeId);
                var aEnd = a.StartTime.AddMinutes(aLt?.DefaultDurationMinutes ?? 60);
                var bEnd = b.StartTime.AddMinutes(bLt?.DefaultDurationMinutes ?? 60);

                if (a.StartTime < bEnd && aEnd > b.StartTime)
                {
                    _conflicts.Add(
                        $"{DayName(a.DayOfWeek)} {a.StartTime:HH:mm}–{aEnd:HH:mm} " +
                        $"överlappar med {b.StartTime:HH:mm}–{bEnd:HH:mm}");
                }
            }
        }
    }

    private bool HasConflict(int dayIndex, TimeOnly start, int durationMinutes)
    {
        if (_template == null) return false;
        var end = start.AddMinutes(durationMinutes);
        return _template.TimeBlocks
            .Where(b => b.WeekNumber == _activeWeek && b.DayOfWeek == dayIndex)
            .Any(b =>
            {
                var bLt  = GetLessonType(b.LessonTypeId);
                var bEnd = b.StartTime.AddMinutes(bLt?.DefaultDurationMinutes ?? 60);
                return start < bEnd && end > b.StartTime;
            });
    }

    private bool IsSlotCovered(int dayIndex, TimeOnly slotTime, int? excludeBlockId = null)
    {
        if (_template == null) return false;
        return _template.TimeBlocks
            .Where(b => b.WeekNumber == _activeWeek && b.DayOfWeek == dayIndex
                     && (excludeBlockId == null || b.Id != excludeBlockId))
            .Any(b =>
            {
                var lt  = GetLessonType(b.LessonTypeId);
                var end = b.StartTime.AddMinutes(lt?.DefaultDurationMinutes ?? 60);
                return slotTime >= b.StartTime && slotTime < end;
            });
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private IEnumerable<ScheduleTimeBlock> GetBlocksForDay(int dayIndex)
        => _template?.TimeBlocks
               .Where(b => b.WeekNumber == _activeWeek && b.DayOfWeek == dayIndex)
               .OrderBy(b => b.StartTime)
           ?? Enumerable.Empty<ScheduleTimeBlock>();

    private LessonType? GetLessonType(int id)
        => BookingService.LessonTypes.FirstOrDefault(l => l.Id == id);

    private static TimeOnly SnapTo5(TimeOnly t)
    {
        var mins = (t.Hour * 60 + t.Minute) / 5 * 5;
        return new TimeOnly(mins / 60, mins % 60);
    }

    // ── Inline tidsedit ───────────────────────────────────────────────────────

    private void StartEditTime(int blockId, TimeOnly currentTime)
    {
        _editingBlockId = blockId;
        _editingTime    = currentTime.ToString("HH:mm");
    }

    private void CommitEditTime(int blockId)
    {
        if (_template != null)
        {
            var block = _template.TimeBlocks.FirstOrDefault(b => b.Id == blockId);
            if (block != null &&
                TimeOnly.TryParseExact(_editingTime, "HH:mm",
                    System.Globalization.CultureInfo.InvariantCulture,
                    System.Globalization.DateTimeStyles.None, out var parsed))
            {
                var snapped = SnapTo5(parsed);
                var lt      = GetLessonType(block.LessonTypeId);
                var endTime = snapped.AddMinutes(lt?.DefaultDurationMinutes ?? 60);
                if (endTime <= new TimeOnly(EndHour, 0))
                {
                    block.StartTime = snapped;
                    ValidateConflicts();
                }
            }
        }
        _editingBlockId = null;
    }

    private void OnTimeEditKey(KeyboardEventArgs e, int blockId)
    {
        if (e.Key == "Enter")  CommitEditTime(blockId);
        if (e.Key == "Escape") _editingBlockId = null;
    }

    private static string DayName(int d) => d switch
    {
        1 => "Måndag", 2 => "Tisdag", 3 => "Onsdag",
        4 => "Torsdag", 5 => "Fredag", 6 => "Lördag", 7 => "Söndag",
        _ => "?"
    };
}
